---
import '../styles/global.css';
import '../styles/pro-layout.css';
import '../styles/site-focused.css';

interface Props {
  title: string;
  description: string;
  navMode?: 'home' | 'article';
}

const { title, description, navMode = 'home' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f6f7fb" />
    <title>{title}</title>
  </head>
  <body>
    <header class="topbar">
      <nav class="shell nav" aria-label="主导航">
        <a class="logo" href="/" aria-label="返回首页">
          <span class="logo-mark">折</span>
          <span>GPT Discount</span>
        </a>

        {navMode === 'home' ? (
          <div class="nav-links" aria-label="分类快捷入口">
            <a href="/#ai-tools">AI 工具优惠</a>
            <a href="/#edu-ai-discounts">教育学生包</a>
            <a href="/#common-software">软件优惠</a>
            <a href="/#cloud-credit">云服务赠金</a>
          </div>
        ) : (
          <div class="nav-links" aria-label="文章目录">
            <a href="#overview">概览</a>
            <a href="#prepare">准备</a>
            <a href="#steps">步骤</a>
            <a href="#faq">排查</a>
          </div>
        )}

        <div class="nav-actions">
          {navMode === 'home' ? (
            <>
              <a class="btn btn-ghost" href="#latest">最近更新</a>
              <a class="btn btn-primary" href="#edu-ai-discounts">学生认证入口</a>
            </>
          ) : (
            <>
              <a class="btn btn-ghost" href="/">返回首页</a>
              <a class="btn btn-primary" href="#steps">看领取步骤</a>
            </>
          )}
        </div>
      </nav>
    </header>

    <slot />

    <footer class="footer">
      <div class="shell footer-inner">
        <span>© GPT Discount · AI 工具与软件优惠领取导航</span>
        <span>只整理公开可复查的优惠入口，不收录黑卡、接码、共享号等高风险路径。</span>
      </div>
    </footer>
  </body>
</html>
