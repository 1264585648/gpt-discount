---
import '../styles/global.css';
import '../styles/pro-layout.css';
import '../styles/site-focused.css';

interface Props {
  title: string;
  description: string;
  navMode?: 'home' | 'article';
}

const { title, description, navMode = 'home' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <title>{title}</title>
  </head>
  <body>
    <header class="topbar">
      <nav class="shell nav" aria-label="主导航">
        <a class="logo" href="/" aria-label="返回 GPT Discount 首页">
          <span class="logo-symbol" aria-hidden="true">
            <svg viewBox="0 0 32 32" role="img">
              <path d="M16 1.8 28 8.7v14L16 29.6 4 22.7v-14L16 1.8Z" fill="currentColor" />
              <path d="m16 8.2 5.8 3.35v6.9L16 21.8l-5.8-3.35v-6.9L16 8.2Z" fill="#fff" opacity=".96" />
            </svg>
          </span>
          <span>GPT Discount</span>
        </a>

        <div class="nav-links" aria-label="分类快捷入口">
          <a href="/#ai-tools">AI 工具优惠</a>
          <a href="/#edu-ai-discounts">教育学生包</a>
          <a href="/#common-software">软件优惠</a>
          <a href="/#cloud-credit">云服务赠金</a>
          <a href="/verification/">学生认证指南</a>
        </div>

        <div class="nav-actions">
          {navMode === 'home' ? (
            <>
              <a class="btn btn-ghost update-link" href="#latest">最近更新</a>
              <a class="btn btn-primary verification-button" href="/verification/">学生认证指南</a>
            </>
          ) : (
            <a class="article-home-button" href="/">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 8h8v8M16 8 7 17" /></svg>
              返回首页
            </a>
          )}
        </div>
      </nav>
    </header>

    <slot />

    <footer class="footer">
      <div class="shell footer-inner">
        <span>© GPT Discount</span>
        {navMode === 'home' && <span>只整理公开可核验的优惠。</span>}
      </div>
    </footer>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const tokenPattern = /\[\[([^|\]]+)\|(https?:\/\/[^\]]+)\]\]/g;
        const targets = document.querySelectorAll(
          '.step-copy p, .step-copy small, .faq-list summary span, .faq-list p'
        );

        targets.forEach((element) => {
          const source = element.textContent || '';
          if (!source.includes('[[')) return;

          const fragment = document.createDocumentFragment();
          let lastIndex = 0;
          let match;
          tokenPattern.lastIndex = 0;

          while ((match = tokenPattern.exec(source)) !== null) {
            fragment.append(source.slice(lastIndex, match.index));

            const link = document.createElement('a');
            link.href = match[2].trim();
            link.textContent = match[1].trim();
            link.target = '_blank';
            link.rel = 'noreferrer';
            fragment.append(link);

            lastIndex = tokenPattern.lastIndex;
          }

          fragment.append(source.slice(lastIndex));
          element.replaceChildren(fragment);
        });
      });
    </script>
  </body>
</html>

<style>
  .logo-symbol {
    width: 30px;
    height: 30px;
    flex: 0 0 auto;
    display: grid;
    place-items: center;
    color: #5046f4;
  }

  .logo-symbol svg {
    width: 30px;
    height: 30px;
    display: block;
  }

  .nav-links {
    padding: 0;
    gap: clamp(16px, 2.4vw, 36px);
    border: 0;
    border-radius: 0;
    background: transparent;
  }

  .nav-links a {
    padding: 8px 0;
    color: #344054;
    font-size: 14px;
    font-weight: 560;
    border-radius: 0;
  }

  .nav-links a:hover {
    color: #4f46e5;
    background: transparent;
  }

  .article-home-button {
    min-height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    padding: 0 17px;
    color: #4f46e5;
    font-size: 14px;
    font-weight: 750;
    line-height: 1;
    border: 1px solid #5b55f7;
    border-radius: 8px;
    background: #fff;
    transition: background-color .18s ease, box-shadow .18s ease;
  }

  .article-home-button:hover {
    background: #f7f7ff;
    box-shadow: 0 7px 18px rgba(79, 70, 229, .1);
  }

  .article-home-button svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  @media (max-width: 1040px) {
    .nav-links { gap: 18px; }
    .nav-links a:last-child { display: none; }
  }

  @media (max-width: 820px) {
    .nav-links { display: none; }
  }

  @media (max-width: 520px) {
    .update-link { display: none; }
    .verification-button { min-height: 38px; padding: 0 12px; font-size: 12px; }
    .article-home-button { min-height: 38px; padding: 0 12px; font-size: 12px; }
  }
</style>

<style is:global>
  .step-copy a,
  .faq-list a {
    color: #4f46e5;
    font-weight: 720;
    text-decoration: underline;
    text-decoration-color: rgba(79, 70, 229, .32);
    text-underline-offset: 3px;
  }

  .step-copy a:hover,
  .faq-list a:hover {
    color: #3730a3;
    text-decoration-color: currentColor;
  }

  .step-copy small {
    line-height: 1.65;
  }
</style>