---
import '../styles/global.css';
import '../styles/pro-layout.css';
import '../styles/site-focused.css';

interface Props {
  title: string;
  description: string;
  navMode?: 'home' | 'article';
}

const { title, description, navMode = 'home' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <title>{title}</title>
  </head>
  <body>
    <header class="topbar">
      <nav class="shell nav" aria-label="主导航">
        <a class="logo" href="/" aria-label="返回 GPT Discount 首页">
          <span class="logo-symbol" aria-hidden="true">
            <svg viewBox="0 0 32 32" role="img">
              <path d="M16 1.8 28 8.7v14L16 29.6 4 22.7v-14L16 1.8Z" fill="currentColor" />
              <path d="m16 8.2 5.8 3.35v6.9L16 21.8l-5.8-3.35v-6.9L16 8.2Z" fill="#fff" opacity=".96" />
            </svg>
          </span>
          <span>GPT Discount</span>
        </a>

        <div class="nav-links" aria-label="分类快捷入口">
          <a href="/#ai-tools">AI 工具优惠</a>
          <a href="/#edu-ai-discounts">学生与教育优惠</a>
          <a href="/#common-software">软件优惠</a>
          <a href="/#cloud-credit">云服务赠金</a>
          <a href="/verification/">学生认证</a>
        </div>

        <div class="nav-actions">
          {navMode === 'home' ? (
            <>
              <a class="btn btn-ghost update-link" href="#latest">最近更新</a>
              <a class="btn btn-primary verification-button" href="/verification/">学生认证</a>
            </>
          ) : (
            <a class="article-home-button" href="/">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 8h8v8M16 8 7 17" /></svg>
              返回首页
            </a>
          )}
        </div>
      </nav>
    </header>

    <slot />

    <footer class="footer">
      <div class="shell footer-inner">
        <span>© GPT Discount</span>
        {navMode === 'home' && <span>AI 工具、学生计划、软件折扣和云服务赠金教程。</span>}
      </div>
    </footer>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const tokenPattern = /\[\[([^|\]]+)\|(https?:\/\/[^\]]+)\]\]/g;
        const targets = document.querySelectorAll('.step-copy p, .step-copy small, .faq-list summary span, .faq-list p');

        targets.forEach((element) => {
          const source = element.textContent || '';
          if (!source.includes('[[')) return;
          const fragment = document.createDocumentFragment();
          let lastIndex = 0;
          let match;
          tokenPattern.lastIndex = 0;

          while ((match = tokenPattern.exec(source)) !== null) {
            fragment.append(source.slice(lastIndex, match.index));
            const link = document.createElement('a');
            link.href = match[2].trim();
            link.textContent = match[1].trim();
            link.target = '_blank';
            link.rel = 'noreferrer';
            fragment.append(link);
            lastIndex = tokenPattern.lastIndex;
          }

          fragment.append(source.slice(lastIndex));
          element.replaceChildren(fragment);
        });

        const hero = document.querySelector('.hero-copy-panel');
        const heroMeta = hero?.querySelector('.hero-meta');
        const priceNode = heroMeta?.querySelector('span:first-child');

        if (hero && heroMeta && priceNode) {
          const price = priceNode.textContent?.trim() || '';
          const pageTitle = hero.querySelector('h1')?.textContent || '';
          const summary = hero.querySelector('.hero-summary')?.textContent || '';
          const status = document.querySelector('.eligibility-status strong')?.textContent?.trim() || '';
          const offerSource = `${pageTitle} ${summary} ${price}`.toLowerCase();
          let offer = { kind: 'deal', label: '优惠', caption: '价格与权益' };

          if (status.includes('已失效')) offer = { kind: 'expired', label: '已结束', caption: '历史价格' };
          else if (status.includes('待验证')) offer = { kind: 'pending', label: '待验证', caption: '页面信息' };
          else if (/(免费试用|free trial|trial)/i.test(offerSource)) offer = { kind: 'trial', label: '免费试用', caption: '试用权益' };
          else if (/(免费额度|赠金|credits?|云额度)/i.test(offerSource)) offer = { kind: 'credit', label: '免费额度', caption: '可用额度' };
          else if (/(免费|零元|0\s*(元|美元|美金|usd|rmb))/i.test(offerSource)) offer = { kind: 'free', label: '免费', caption: '免费权益' };
          else if (/(折扣|学生价|优惠价|首年|半价|减免|立减|优惠)/i.test(offerSource)) offer = { kind: 'discount', label: '折扣', caption: '优惠价格' };

          const callout = document.createElement('div');
          callout.className = `global-offer-highlight is-${offer.kind}`;
          callout.setAttribute('aria-label', `${offer.label}：${price}`);
          const badge = document.createElement('span');
          badge.className = 'global-offer-badge';
          badge.textContent = offer.label;
          const copy = document.createElement('div');
          const caption = document.createElement('small');
          const value = document.createElement('strong');
          caption.textContent = offer.caption;
          value.textContent = price;
          copy.append(caption, value);
          callout.append(badge, copy);
          heroMeta.before(callout);
          priceNode.remove();

          const applyLabel = status.includes('已失效') ? '查看官方状态' : status.includes('待验证') ? '查看官方页面' : '打开申请页面';
          document.querySelectorAll('.primary-action, .mobile-apply-bar a').forEach((element) => {
            const svg = element.querySelector('svg');
            element.replaceChildren(document.createTextNode(applyLabel));
            if (svg) element.append(svg);
          });
        }
      });
    </script>
  </body>
</html>

<style>
  .logo-symbol { width: 30px; height: 30px; flex: 0 0 auto; display: grid; place-items: center; color: #5046f4; }
  .logo-symbol svg { width: 30px; height: 30px; display: block; }
  .nav-links { padding: 0; gap: clamp(16px, 2.4vw, 36px); border: 0; border-radius: 0; background: transparent; }
  .nav-links a { padding: 8px 0; color: #344054; font-size: 14px; font-weight: 560; border-radius: 0; }
  .nav-links a:hover { color: #4f46e5; background: transparent; }
  .article-home-button { min-height: 42px; display: inline-flex; align-items: center; justify-content: center; gap: 9px; padding: 0 17px; color: #4f46e5; font-size: 14px; font-weight: 750; line-height: 1; border: 1px solid #5b55f7; border-radius: 8px; background: #fff; }
  .article-home-button:hover { background: #f7f7ff; box-shadow: 0 7px 18px rgba(79, 70, 229, .1); }
  .article-home-button svg { width: 16px; height: 16px; fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
  @media (max-width: 1040px) { .nav-links { gap: 18px; } .nav-links a:last-child { display: none; } }
  @media (max-width: 820px) { .nav-links { display: none; } }
  @media (max-width: 520px) { .update-link { display: none; } .verification-button, .article-home-button { min-height: 38px; padding: 0 12px; font-size: 12px; } }
</style>

<style is:global>
  .step-copy a, .faq-list a { color: #4f46e5; font-weight: 720; text-decoration: underline; text-decoration-color: rgba(79, 70, 229, .32); text-underline-offset: 3px; }
  .step-copy a:hover, .faq-list a:hover { color: #3730a3; text-decoration-color: currentColor; }
  .step-copy small { line-height: 1.65; }
  .global-offer-highlight { max-width: 760px; display: grid; grid-template-columns: auto minmax(0, 1fr); gap: 18px; align-items: center; margin-top: 24px; padding: 17px 18px; border: 1px solid rgba(15, 159, 110, .24); border-radius: 10px; background: linear-gradient(135deg, #effcf6, #f8fffb); box-shadow: 0 8px 22px rgba(15, 159, 110, .08); }
  .global-offer-badge { min-width: 88px; min-height: 48px; display: grid; place-items: center; padding: 0 14px; color: #fff; font-size: 16px; font-weight: 900; letter-spacing: .04em; border-radius: 8px; background: #0f9f6e; box-shadow: 0 8px 18px rgba(15, 159, 110, .2); }
  .global-offer-highlight small, .global-offer-highlight strong { display: block; }
  .global-offer-highlight small { color: #667085; font-size: 12px; font-weight: 750; }
  .global-offer-highlight strong { margin-top: 3px; color: #173a2c; font-size: clamp(17px, 2vw, 21px); line-height: 1.35; overflow-wrap: anywhere; }
  .global-offer-highlight.is-credit { border-color: #cbdcff; background: linear-gradient(135deg, #f2f7ff, #f8fbff); }
  .global-offer-highlight.is-credit .global-offer-badge { background: #2563eb; }
  .global-offer-highlight.is-credit strong { color: #173a73; }
  .global-offer-highlight.is-discount { border-color: #ffd7ad; background: linear-gradient(135deg, #fff7ed, #fffdf9); }
  .global-offer-highlight.is-discount .global-offer-badge { background: #e9730c; }
  .global-offer-highlight.is-discount strong { color: #71350d; }
  .global-offer-highlight.is-trial { border-color: #b9e8ef; background: linear-gradient(135deg, #effbfd, #f9feff); }
  .global-offer-highlight.is-trial .global-offer-badge { background: #0891b2; }
  .global-offer-highlight.is-trial strong { color: #155260; }
  .global-offer-highlight.is-expired { border-color: #f0caca; background: linear-gradient(135deg, #fff5f5, #fffafa); }
  .global-offer-highlight.is-expired .global-offer-badge { background: #c43d3d; }
  .global-offer-highlight.is-expired strong { color: #7c2626; }
  .global-offer-highlight.is-pending { border-color: #efdfb7; background: linear-gradient(135deg, #fffaf0, #fffdf8); }
  .global-offer-highlight.is-pending .global-offer-badge { background: #b77900; }
  .global-offer-highlight.is-pending strong { color: #6e4a00; }
  .global-offer-highlight.is-deal { border-color: #d7d4ff; background: linear-gradient(135deg, #f6f5ff, #fbfaff); }
  .global-offer-highlight.is-deal .global-offer-badge { background: #5147f5; }
  .global-offer-highlight.is-deal strong { color: #3730a3; }
  @media (max-width: 620px) { .global-offer-highlight { grid-template-columns: 1fr; gap: 10px; margin-top: 18px; padding: 14px; } .global-offer-badge { width: fit-content; min-width: 0; min-height: 36px; padding: 0 13px; font-size: 14px; } }
</style>