---
import TopicLayout from '../../layouts/TopicLayout.astro';
import TopicCoverVisual from '../../components/TopicCoverVisual.astro';
import { topics, type Topic } from '../../data/topics';
import { getGuidesByCategory, type Guide } from '../../data/guides';

export async function getStaticPaths() {
  return topics.map((topic) => ({ params: { slug: topic.slug }, props: { topic } }));
}

const { topic } = Astro.props as { topic: Topic };
const guides = await getGuidesByCategory(topic.categorySlug);
const relatedTopics = topic.relatedTopics
  .map((slug) => topics.find((item) => item.slug === slug))
  .filter((item): item is Topic => Boolean(item))
  .slice(0, 3);

const statusRank: Record<string, number> = { 可领取: 1, 待验证: 6, 已失效: 7 };
const sortedGuides = [...guides].sort((a, b) => {
  const statusDiff = (statusRank[a.status] ?? 4) - (statusRank[b.status] ?? 4);
  if (statusDiff !== 0) return statusDiff;
  return (a.order ?? 999) - (b.order ?? 999);
});

const searchable = (guide: Guide) => [
  guide.title,
  guide.summary,
  guide.dealType,
  guide.dealPrice,
  guide.audience,
  guide.region,
  guide.warning,
].filter(Boolean).join(' ');

const presentationStatus = (guide: Guide) => {
  const text = searchable(guide);
  if (guide.status === '已失效') return { label: '已结束', className: 'expired', cta: '查看历史状态' };
  if (guide.status === '待验证') return { label: '待验证', className: 'pending', cta: '查看核验说明' };
  if (/学校授权|学校统一|教师身份|教育机构/.test(text)) return { label: '需要学校授权', className: 'school', cta: '查看领取教程' };
  if (/限时|活动|首年/.test(text)) return { label: '限时活动', className: 'limited', cta: '查看领取教程' };
  if (/部分地区|指定地区|地区限制/.test(text)) return { label: '部分地区可用', className: 'regional', cta: '查看领取教程' };
  if (/免费|赠金|额度|0\s*(元|美元|美金|usd)/i.test(`${guide.dealPrice} ${guide.dealType}`)) return { label: '免费使用', className: 'free', cta: '查看领取教程' };
  return { label: '可领取', className: 'available', cta: '查看领取教程' };
};

const categoryFor = (guide: Guide) => {
  const text = searchable(guide);
  if (guide.status === '已失效') return '已结束';
  if (/学校授权|学校统一|教师身份|教育机构/.test(text)) return '学校授权';
  if (/限时|活动|首年/.test(text)) return '限时活动';
  if (/折扣|学生价|优惠价|减免|半价/.test(text)) return '学生折扣';
  if (/免费|赠金|额度|0\s*(元|美元|美金|usd)/i.test(`${guide.dealPrice} ${guide.dealType}`)) return '免费权益';
  return '其他';
};

const categoryOrder = ['免费权益', '学生折扣', '学校授权', '限时活动', '已结束', '其他'];
const availableCategories = categoryOrder.filter((category) => sortedGuides.some((guide) => categoryFor(guide) === category));
const initialVisible = 9;

const initials = (title: string) => {
  const latin = title.match(/[A-Za-z0-9]+/g)?.join(' ') ?? '';
  if (latin) return latin.split(/\s+/).slice(0, 2).map((part) => part[0]).join('').toUpperCase();
  return title.replace(/[\s·/]/g, '').slice(0, 2);
};

const iconClass = (title: string) => {
  const value = title.toLowerCase();
  if (value.includes('github')) return 'github';
  if (value.includes('jetbrains')) return 'jetbrains';
  if (value.includes('notion')) return 'notion';
  if (value.includes('google')) return 'google';
  if (value.includes('adobe')) return 'adobe';
  if (value.includes('figma')) return 'figma';
  if (value.includes('canva')) return 'canva';
  if (value.includes('openai') || value.includes('chatgpt')) return 'openai';
  return 'default';
};
---
<TopicLayout title={`${topic.title}｜GPT Discount`} description={topic.description} topic={topic}>
  <main class="topic-page">
    <section class="topic-shell topic-hero" aria-labelledby="topic-title">
      <div class="topic-hero-copy">
        <span class="topic-eyebrow">GPT Discount 专题</span>
        <h1 id="topic-title">{topic.title}</h1>
        <p class="topic-slogan">{topic.slogan}</p>
        <p class="topic-description">{topic.description}</p>
        <div class="topic-cover-note">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3 20 6v6c0 5-3.4 8-8 9-4.6-1-8-4-8-9V6l8-3Z" /><path d="m8.5 12 2.2 2.2 4.8-5" /></svg>
          <span>{topic.coverNote}</span>
        </div>
        <a class="topic-scroll-link" href="#all-deals">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 4v16m-6-6 6 6 6-6" /></svg>
          向下查看全部优惠
        </a>
      </div>
      <TopicCoverVisual visual={topic.visual} />
    </section>

    <section class="topic-shell topic-deals" id="all-deals">
      <div class="topic-section-heading">
        <div>
          <h2>全部优惠</h2>
          <p>持续整理和核验该专题下的公开优惠与领取教程。</p>
        </div>
        <div class="topic-toolbar">
          <label class="topic-search-field" for="topic-search">
            <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="m20 20-4-4" /></svg>
            <input id="topic-search" type="search" placeholder="搜索优惠名称或关键词" autocomplete="off" />
          </label>
          <label class="topic-sort-field">
            <span class="sr-only">优惠排序</span>
            <select id="topic-sort" aria-label="优惠排序">
              <option value="default">默认推荐</option>
              <option value="verified">最新核验</option>
              <option value="title">名称排序</option>
            </select>
            <svg viewBox="0 0 16 16" aria-hidden="true"><path d="m4 6 4 4 4-4" /></svg>
          </label>
        </div>
      </div>

      {availableCategories.length > 0 && (
        <div class="topic-category-row" role="tablist" aria-label="优惠分类">
          <button class="active" type="button" data-category="全部">全部</button>
          {availableCategories.map((category) => <button type="button" data-category={category}>{category}</button>)}
        </div>
      )}

      {sortedGuides.length > 0 ? (
        <>
          <div class="topic-deal-grid" data-deal-grid>
            {sortedGuides.map((guide, index) => {
              const status = presentationStatus(guide);
              const category = categoryFor(guide);
              const coreBenefit = guide.dealPrice || guide.benefits?.[0]?.value || guide.dealType;
              return (
                <a
                  class:list={['topic-deal-card', `is-${status.className}`, { 'is-initially-hidden': index >= initialVisible }]}
                  href={`/guides/${guide.slug}/`}
                  data-deal-card
                  data-category={category}
                  data-search={searchable(guide).toLowerCase()}
                  data-title={guide.title}
                  data-verified={guide.lastVerified}
                  data-default-order={index}
                >
                  <div class="deal-card-topline">
                    <span class={`deal-brand-mark is-${iconClass(guide.title)}`}>{initials(guide.title)}</span>
                    <span class={`deal-status is-${status.className}`}>{status.label}</span>
                  </div>
                  <div class="deal-card-copy">
                    <h3>{guide.title}</h3>
                    <p>{guide.summary}</p>
                    <strong class="deal-benefit">
                      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m12 3 2.2 6.8L21 12l-6.8 2.2L12 21l-2.2-6.8L3 12l6.8-2.2L12 3Z" /></svg>
                      <span>{coreBenefit}</span>
                    </strong>
                  </div>
                  <div class="deal-card-footer">
                    <span class="deal-warning">
                      <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9" /><path d="M12 8v5m0 3h.01" /></svg>
                      <span>{guide.warning}</span>
                    </span>
                    <span class="deal-cta">{status.cta}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" /></svg></span>
                  </div>
                </a>
              );
            })}
          </div>
          <div class="topic-empty-results" hidden data-empty-results>
            <strong>没有找到匹配的优惠</strong>
            <span>可以尝试更换关键词或查看其他分类。</span>
          </div>
          {sortedGuides.length > initialVisible && (
            <button class="topic-load-more" type="button" data-load-more>
              加载更多优惠
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m6 9 6 6 6-6" /></svg>
            </button>
          )}
        </>
      ) : (
        <div class="topic-content-empty">
          <span aria-hidden="true"><svg viewBox="0 0 48 48"><rect x="6" y="9" width="36" height="30" rx="8" /><path d="M15 19h18M15 27h12" /></svg></span>
          <h3>该专题内容正在整理中</h3>
          <p>我们正在核验公开入口、领取条件和当前状态。</p>
          <div><a href="/">返回首页</a><a href={`/topics/${relatedTopics[0]?.slug ?? 'student-education'}/`}>查看其他专题</a></div>
        </div>
      )}
    </section>

    <section class="topic-shell topic-related" aria-labelledby="related-title">
      <div class="topic-related-heading"><h2 id="related-title">浏览其他专题</h2></div>
      <div class="topic-related-grid">
        {relatedTopics.map((item) => (
          <a class={`related-topic-card is-${item.visual}`} href={`/topics/${item.slug}/`}>
            <span class="related-topic-art" aria-hidden="true">
              <svg viewBox="0 0 150 100">
                {item.visual === 'ai' && <><rect x="16" y="22" width="70" height="48" rx="14" /><path d="m34 70-9 16 24-16" /><circle cx="40" cy="45" r="5" /><circle cx="57" cy="45" r="5" /><circle cx="74" cy="45" r="5" /><circle cx="111" cy="45" r="23" /><path d="m111 29 5 12 13 2-10 8 3 13-11-7-11 7 3-13-10-8 13-2 5-12Z" /></>}
                {item.visual === 'education' && <><path d="m18 34 42-20 42 20-42 20-42-20Z" /><path d="M33 43v26c17 11 37 11 54 0V43" /><rect x="92" y="50" width="42" height="34" rx="8" /><circle cx="106" cy="62" r="6" /><path d="M99 77c4-8 11-8 15 0" /></>}
                {item.visual === 'software' && <><rect x="14" y="18" width="92" height="66" rx="12" /><path d="M14 34h92" /><circle cx="27" cy="26" r="3" /><circle cx="38" cy="26" r="3" /><path d="m109 46 11 11 20-20 9 9-20 20 8 8-17 17-8-8-15 15-12-12 15-15-8-8 17-17Z" /></>}
                {item.visual === 'cloud' && <><path d="M33 66h78c18 0 24-24 8-32-7-4-14-3-20 0-5-19-29-27-44-13-7 6-10 13-9 21-17-4-30 8-30 23 0 1 0 1 1 1h16Z" /><rect x="24" y="69" width="60" height="19" rx="7" /><path d="M98 55 122 63v16c0 15-11 22-24 27-13-5-24-12-24-27V63l24-8Z" /><path d="m87 78 8 8 14-17" /></>}
              </svg>
            </span>
            <span class="related-topic-copy"><strong>{item.title}</strong><small>{item.slogan}</small></span>
            <span class="related-topic-arrow"><svg viewBox="0 0 24 24"><path d="M5 12h14m-6-6 6 6-6 6" /></svg></span>
          </a>
        ))}
      </div>
    </section>
  </main>

  <script is:inline>
    (() => {
      const input = document.querySelector('#topic-search');
      const sort = document.querySelector('#topic-sort');
      const grid = document.querySelector('[data-deal-grid]');
      const cards = [...document.querySelectorAll('[data-deal-card]')];
      const categoryButtons = [...document.querySelectorAll('[data-category]')];
      const empty = document.querySelector('[data-empty-results]');
      const loadMore = document.querySelector('[data-load-more]');
      let activeCategory = '全部';
      let expanded = false;

      const apply = () => {
        const query = (input?.value || '').trim().toLowerCase();
        let visibleCount = 0;
        let matchingCount = 0;
        cards.forEach((card) => {
          const categoryMatch = activeCategory === '全部' || card.dataset.category === activeCategory;
          const searchMatch = !query || (card.dataset.search || '').includes(query);
          const matches = categoryMatch && searchMatch;
          if (matches) matchingCount += 1;
          const withinLimit = expanded || visibleCount < 9;
          const show = matches && withinLimit;
          card.hidden = !show;
          card.classList.remove('is-initially-hidden');
          if (show) visibleCount += 1;
        });
        if (empty) empty.hidden = matchingCount !== 0;
        if (loadMore) loadMore.hidden = expanded || matchingCount <= 9;
      };

      const reorder = () => {
        const mode = sort?.value || 'default';
        const ordered = [...cards].sort((a, b) => {
          if (mode === 'title') return (a.dataset.title || '').localeCompare(b.dataset.title || '', 'zh-CN');
          if (mode === 'verified') return (b.dataset.verified || '').localeCompare(a.dataset.verified || '');
          return Number(a.dataset.defaultOrder || 0) - Number(b.dataset.defaultOrder || 0);
        });
        ordered.forEach((card) => grid?.appendChild(card));
        apply();
      };

      categoryButtons.forEach((button) => button.addEventListener('click', () => {
        activeCategory = button.dataset.category || '全部';
        expanded = false;
        categoryButtons.forEach((item) => item.classList.toggle('active', item === button));
        apply();
      }));
      input?.addEventListener('input', () => { expanded = false; apply(); });
      sort?.addEventListener('change', reorder);
      loadMore?.addEventListener('click', () => { expanded = true; apply(); });
      apply();
    })();
  </script>
</TopicLayout>
