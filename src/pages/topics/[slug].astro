---
import TopicLayout from '../../layouts/TopicLayout.astro';
import TopicCoverVisual from '../../components/TopicCoverVisual.astro';
import TopicDealRow from '../../components/TopicDealRow.astro';
import { topics, type Topic } from '../../data/topics';
import {
  getGuidePresentationCategory,
  getGuides,
  getGuidesByCategory,
  type Guide,
} from '../../data/guides';

export async function getStaticPaths() {
  return topics.map((topic) => ({ params: { slug: topic.slug }, props: { topic } }));
}

const { topic } = Astro.props as { topic: Topic };
const isAiTopic = topic.slug === 'ai-tools';
const allGuides = await getGuides();
const guides = isAiTopic ? [] : await getGuidesByCategory(topic.categorySlug);

const relatedTopics = topic.relatedTopics
  .map((slug) => topics.find((item) => item.slug === slug))
  .filter((item): item is Topic => Boolean(item))
  .slice(0, 3);

const categoryOrder = ['可领取', '学生优惠', '学校授权', '限时活动', '地区限制', '待验证', '已结束'];
const rank = Object.fromEntries(categoryOrder.map((category, index) => [category, index]));
const sortedGuides = [...guides].sort(
  (a, b) => (rank[getGuidePresentationCategory(a)] ?? 9) - (rank[getGuidePresentationCategory(b)] ?? 9)
    || (a.order ?? 999) - (b.order ?? 999)
);
const categoryCounts = Object.fromEntries(
  categoryOrder.map((category) => [
    category,
    sortedGuides.filter((guide) => getGuidePresentationCategory(guide) === category).length,
  ])
);
const availableCategories = categoryOrder.filter((category) => categoryCounts[category] > 0);

const aiProductDefinitions = [
  {
    slug: 'chatgpt',
    label: 'ChatGPT',
    owner: 'OpenAI',
    mark: 'GPT',
    description: 'Free、Go、Plus、Pro、应用内购买与教育方案。',
  },
  {
    slug: 'claude',
    label: 'Claude',
    owner: 'Anthropic',
    mark: 'CL',
    description: 'Claude Free、Pro、Max 与学校授权。',
  },
  {
    slug: 'gemini',
    label: 'Gemini',
    owner: 'Google',
    mark: 'G',
    description: 'Gemini 免费版、Google AI Pro 与学生活动。',
  },
  {
    slug: 'grok',
    label: 'Grok',
    owner: 'xAI / X',
    mark: 'X',
    description: '免费额度、SuperGrok 与 X Premium 相关权益。',
  },
  {
    slug: 'cursor',
    label: 'Cursor',
    owner: 'Anysphere',
    mark: 'CU',
    description: '免费版、付费订阅与可能开放的资格活动。',
  },
  {
    slug: 'perplexity',
    label: 'Perplexity',
    owner: 'Perplexity AI',
    mark: 'P',
    description: '免费版、Pro 订阅与合作活动。',
  },
  {
    slug: 'other',
    label: '其他 AI 工具',
    owner: '更多产品',
    mark: '+',
    description: '尚未完成产品字段迁移的 AI 工具教程。',
  },
] as const;

const aiGuides = allGuides.filter((guide) =>
  guide.categorySlug === 'ai-tools' || guide.relatedCategorySlugs?.includes('ai-tools')
);

const aiProducts = aiProductDefinitions
  .map((product) => ({
    ...product,
    guides: aiGuides
      .filter((guide) => product.slug === 'other'
        ? !guide.productSlug || guide.productSlug === 'other'
        : guide.productSlug === product.slug)
      .sort((a, b) => (a.order ?? 999) - (b.order ?? 999)),
  }))
  .filter((product) => product.guides.length > 0);

const heroTags: Record<Topic['visual'], string[]> = {
  education: ['学生认证', '教育邮箱', '学校授权'],
  ai: ['免费版', '付费订阅', '领取教程'],
  software: ['办公效率', '设计开发', '订阅价格'],
  cloud: ['新用户赠金', '免费额度', '计费规则'],
};

const initialVisible = 8;
---

<TopicLayout title={`${topic.title}｜GPT Discount`} description={topic.description} topic={topic}>
  <main class="topic-page">
    <div class="topic-shell topic-breadcrumb" aria-label="面包屑">
      <a href="/">首页</a>
      <span aria-hidden="true">/</span>
      <strong>{topic.title}</strong>
    </div>

    <section class="topic-shell topic-hero" aria-labelledby="topic-title">
      <div class="topic-hero-copy">
        <span class="topic-eyebrow">优惠分类</span>
        <h1 id="topic-title">{topic.title}</h1>
        <p class="topic-description">{topic.description}</p>
        <div class="topic-tag-row" aria-label="分类内容">
          {heroTags[topic.visual].map((tag) => (
            <span>
              <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12 2.2 2.2 4.8-5"/></svg>
              {tag}
            </span>
          ))}
        </div>
      </div>
      <TopicCoverVisual visual={topic.visual} />
    </section>

    <section class="topic-shell topic-deals" id="all-deals" aria-labelledby="all-deals-title">
      {isAiTopic ? (
        <>
          <div class="topic-deals-header ai-topic-heading">
            <div>
              <span class="topic-section-kicker">按产品查看</span>
              <h2 id="all-deals-title">AI 工具订阅与优惠教程</h2>
              <p>选择产品，直接查看当前可用方案、限制和具体操作。</p>
            </div>
          </div>

          {aiProducts.length > 0 ? (
            <>
              <nav class="ai-product-nav" aria-label="AI 产品分类">
                {aiProducts.map((product) => (
                  <a href={`#${product.slug}`}>
                    <span class={`ai-product-nav-mark is-${product.slug}`}>{product.mark}</span>
                    <span><strong>{product.label}</strong><small>{product.owner}</small></span>
                  </a>
                ))}
              </nav>

              <div class="ai-product-groups" data-ai-product-groups>
                {aiProducts.map((product) => (
                  <section class="ai-product-group" id={product.slug} aria-labelledby={`${product.slug}-title`}>
                    <div class="ai-product-group-heading">
                      <span class={`ai-product-group-mark is-${product.slug}`}>{product.mark}</span>
                      <div>
                        <small>{product.owner}</small>
                        <h3 id={`${product.slug}-title`}>{product.label}</h3>
                        <p>{product.description}</p>
                      </div>
                    </div>
                    <div class="topic-deal-list">
                      {product.guides.map((guide, index) => (
                        <TopicDealRow guide={guide} defaultOrder={index} />
                      ))}
                    </div>
                  </section>
                ))}
              </div>
            </>
          ) : (
            <div class="topic-content-empty">
              <h3>目前没有已完成的 AI 工具教程</h3>
              <p>文章完成并发布后会自动出现在这里。</p>
              <div><a href="/">返回首页</a></div>
            </div>
          )}
        </>
      ) : (
        <>
          <div class="topic-deals-header">
            <div>
              <span class="topic-section-kicker">优惠列表</span>
              <h2 id="all-deals-title">{topic.title}</h2>
              <p>{topic.coverNote}。打开具体优惠可查看领取步骤和常见问题。</p>
            </div>
            <label class="topic-sort-field">
              <span class="sr-only">优惠排序</span>
              <select id="topic-sort" aria-label="优惠排序">
                <option value="default">默认排序</option>
                <option value="verified">最近核验</option>
                <option value="title">名称排序</option>
              </select>
              <svg viewBox="0 0 16 16" aria-hidden="true"><path d="m4 6 4 4 4-4"/></svg>
            </label>
          </div>

          {availableCategories.length > 0 && (
            <div class="topic-filter-row" role="tablist" aria-label="优惠状态筛选">
              <button class="active" type="button" data-category="全部"><span>全部</span><small>{sortedGuides.length}</small></button>
              {availableCategories.map((category) => (
                <button type="button" data-category={category}><span>{category}</span><small>{categoryCounts[category]}</small></button>
              ))}
            </div>
          )}

          {sortedGuides.length > 0 ? (
            <>
              <div class="topic-deal-list" data-deal-list>
                {sortedGuides.map((guide, index) => (
                  <TopicDealRow guide={guide} initiallyHidden={index >= initialVisible} defaultOrder={index} />
                ))}
              </div>
              <div class="topic-empty-results" hidden data-empty-results>
                <strong>没有符合当前筛选的优惠</strong>
                <span>可切换到“全部”查看本分类的其他内容。</span>
              </div>
              {sortedGuides.length > initialVisible && (
                <button class="topic-load-more" type="button" data-load-more>
                  加载更多优惠
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
                </button>
              )}
            </>
          ) : (
            <div class="topic-content-empty">
              <h3>目前没有可查看的优惠</h3>
              <p>可返回首页或查看其他优惠分类。</p>
              <div><a href="/">返回首页</a><a href={`/topics/${relatedTopics[0]?.slug ?? 'student-education'}/`}>查看其他分类</a></div>
            </div>
          )}
        </>
      )}
    </section>

    <section class="topic-shell topic-related" aria-labelledby="related-title">
      <div class="topic-related-heading">
        <div><span class="topic-section-kicker">其他分类</span><h2 id="related-title">你可能还在找</h2></div>
        <a href="/#all-guides">查看全部分类 <span aria-hidden="true">→</span></a>
      </div>
      <div class="topic-related-grid">
        {relatedTopics.map((item) => (
          <a class={`related-topic-card is-${item.visual}`} href={`/topics/${item.slug}/`}>
            <span class="related-topic-art" aria-hidden="true"></span>
            <span class="related-topic-copy"><strong>{item.title}</strong><small>{item.slogan}</small><em>查看优惠 <span aria-hidden="true">→</span></em></span>
          </a>
        ))}
      </div>
    </section>
  </main>

  <style is:global>
    .ai-topic-heading { align-items: flex-start; }

    .ai-product-nav {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
      gap: 10px;
      margin-top: 24px;
      padding-bottom: 24px;
      border-bottom: 1px solid #edf0f4;
    }

    .ai-product-nav a {
      min-height: 76px;
      display: grid;
      grid-template-columns: 44px minmax(0, 1fr);
      align-items: center;
      gap: 12px;
      padding: 13px 14px;
      border: 1px solid #e4e8ef;
      border-radius: 13px;
      background: #fff;
      transition: border-color .18s ease, box-shadow .18s ease, transform .18s ease;
    }

    .ai-product-nav a:hover {
      border-color: color-mix(in srgb, var(--topic-accent) 25%, #e4e8ef);
      box-shadow: 0 10px 24px rgba(15, 23, 42, .06);
      transform: translateY(-1px);
    }

    .ai-product-nav-mark,
    .ai-product-group-mark {
      display: grid;
      place-items: center;
      color: #fff;
      border-radius: 12px;
      background: #111827;
      font-size: 12px;
      font-weight: 900;
      letter-spacing: -.035em;
    }

    .ai-product-nav-mark { width: 44px; height: 44px; }
    .ai-product-nav-mark.is-claude,
    .ai-product-group-mark.is-claude { background: #d97757; }
    .ai-product-nav-mark.is-gemini,
    .ai-product-group-mark.is-gemini { background: linear-gradient(135deg, #4285f4, #8e75d6 50%, #d96570); }
    .ai-product-nav-mark.is-grok,
    .ai-product-group-mark.is-grok { background: #050505; }
    .ai-product-nav-mark.is-cursor,
    .ai-product-group-mark.is-cursor { background: #22252b; }
    .ai-product-nav-mark.is-perplexity,
    .ai-product-group-mark.is-perplexity { background: #178b8b; }
    .ai-product-nav-mark.is-other,
    .ai-product-group-mark.is-other { background: #4f46e5; }

    .ai-product-nav strong,
    .ai-product-nav small { display: block; }
    .ai-product-nav strong { color: #182033; font-size: 14px; }
    .ai-product-nav small { margin-top: 4px; color: #8a92a3; font-size: 10px; }

    .ai-product-groups {
      display: grid;
      gap: 30px;
      padding-top: 28px;
    }

    .ai-product-group { scroll-margin-top: 96px; }
    .ai-product-group + .ai-product-group {
      padding-top: 28px;
      border-top: 1px solid #edf0f4;
    }

    .ai-product-group-heading {
      display: grid;
      grid-template-columns: 54px minmax(0, 1fr);
      align-items: center;
      gap: 15px;
    }

    .ai-product-group-mark {
      width: 54px;
      height: 54px;
      border-radius: 15px;
      font-size: 14px;
    }

    .ai-product-group-heading small,
    .ai-product-group-heading h3,
    .ai-product-group-heading p { display: block; margin: 0; }
    .ai-product-group-heading small {
      color: var(--topic-accent);
      font-size: 10px;
      font-weight: 780;
      text-transform: uppercase;
      letter-spacing: .08em;
    }
    .ai-product-group-heading h3 {
      margin-top: 3px;
      color: #151a28;
      font-size: 23px;
      line-height: 1.2;
      letter-spacing: -.03em;
    }
    .ai-product-group-heading p {
      margin-top: 5px;
      color: #697184;
      font-size: 12px;
      line-height: 1.55;
    }
    .ai-product-group .topic-deal-list { padding-top: 14px; }

    @media (max-width: 760px) {
      .ai-product-nav { grid-template-columns: 1fr; gap: 8px; }
      .ai-product-nav a { min-height: 66px; }
      .ai-product-group-heading { grid-template-columns: 48px minmax(0, 1fr); }
      .ai-product-group-mark { width: 48px; height: 48px; }
      .ai-product-group-heading h3 { font-size: 20px; }
    }
  </style>

  <script is:inline>
    (() => {
      if (document.querySelector('[data-ai-product-groups]')) return;
      const sort = document.querySelector('#topic-sort');
      const list = document.querySelector('[data-deal-list]');
      const cards = [...document.querySelectorAll('[data-deal-card]')];
      const buttons = [...document.querySelectorAll('[data-category]')];
      const empty = document.querySelector('[data-empty-results]');
      const more = document.querySelector('[data-load-more]');
      let active = '全部';
      let expanded = false;

      const apply = () => {
        let shown = 0;
        let matches = 0;
        cards.forEach((card) => {
          const ok = active === '全部' || card.dataset.category === active;
          if (ok) matches += 1;
          const show = ok && (expanded || shown < 8);
          card.hidden = !show;
          card.classList.remove('is-initially-hidden');
          if (show) shown += 1;
        });
        if (empty) empty.hidden = matches !== 0;
        if (more) more.hidden = expanded || matches <= 8;
      };

      const reorder = () => {
        const mode = sort?.value || 'default';
        [...cards]
          .sort((a, b) => mode === 'title'
            ? (a.dataset.title || '').localeCompare(b.dataset.title || '', 'zh-CN')
            : mode === 'verified'
              ? (b.dataset.verified || '').localeCompare(a.dataset.verified || '')
              : Number(a.dataset.defaultOrder || 0) - Number(b.dataset.defaultOrder || 0))
          .forEach((card) => list?.appendChild(card));
        apply();
      };

      buttons.forEach((button) => button.addEventListener('click', () => {
        active = button.dataset.category || '全部';
        expanded = false;
        buttons.forEach((item) => item.classList.toggle('active', item === button));
        apply();
      }));
      sort?.addEventListener('change', reorder);
      more?.addEventListener('click', () => { expanded = true; apply(); });
      apply();
    })();
  </script>
</TopicLayout>
