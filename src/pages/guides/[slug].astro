---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/deal-detail.css';
import { getGuides } from '../../data/guides';

export async function getStaticPaths() {
  const guides = await getGuides();
  return guides.map((guide) => ({ params: { slug: guide.slug }, props: { guide } }));
}

const { guide } = Astro.props;
const requirements = guide.requirements.length
  ? guide.requirements
  : guide.preparation.map((label) => ({ label, level: 'required' as const, guide: undefined }));

const statusClass = guide.status === '可领取'
  ? 'is-available'
  : guide.status === '已失效'
    ? 'is-expired'
    : 'is-pending';

const needsStudentVerification = Boolean(
  guide.verification
  || guide.eligibilityType === '学生认证'
  || guide.offerType === '学生优惠'
  || guide.offerType === '学校授权'
  || guide.availabilityScope === '学校或机构'
);

const officialLabel = guide.status === '已失效'
  ? '查看官方状态'
  : guide.offerType === '学生优惠' || guide.offerType === '学校授权'
    ? '打开官方申请'
    : guide.offerType === '普通订阅'
      ? '查看官方订阅'
      : guide.offerKind === 'credit'
        ? '查看官方赠金'
        : '打开官方页面';

const verificationDetails = [
  guide.verificationType,
  `${guide.lastVerified} 核验`,
  guide.priceVerifiedAt ? `价格 ${guide.priceVerifiedAt}` : undefined,
  guide.benefitsVerifiedAt ? `权益 ${guide.benefitsVerifiedAt}` : undefined,
].filter(Boolean).join(' · ');

const contentTypeLabels = {
  '领取教程': {
    benefits: '主要权益',
    benefitsLink: '查看主要权益',
    requirements: '开始前确认',
    steps: '操作步骤',
    faq: '常见问题',
    warning: '费用与限制',
    typeClass: 'is-claim-guide',
  },
  '状态核验': {
    benefits: '当前状态',
    benefitsLink: '查看当前状态',
    requirements: '需要核对',
    steps: '检查方法',
    faq: '后续处理',
    warning: '状态说明',
    typeClass: 'is-status-check',
  },
  '方案对比': {
    benefits: '方案概览',
    benefitsLink: '查看方案概览',
    requirements: '选择前确认',
    steps: '判断顺序',
    faq: '选择疑问',
    warning: '适用限制',
    typeClass: 'is-comparison',
  },
  '学校授权': {
    benefits: '授权内容',
    benefitsLink: '查看授权内容',
    requirements: '资格与授权',
    steps: '获取方式',
    faq: '授权问题',
    warning: '学校与账号限制',
    typeClass: 'is-school-license',
  },
  '风险说明': {
    benefits: '影响范围',
    benefitsLink: '查看影响范围',
    requirements: '风险前提',
    steps: '处理建议',
    faq: '风险问答',
    warning: '重要风险',
    typeClass: 'is-risk-note',
  },
} as const;

const contentLabels = contentTypeLabels[guide.contentType as keyof typeof contentTypeLabels]
  ?? contentTypeLabels['领取教程'];

const conditionItems = [
  ...requirements,
  ...(guide.verification
    ? [{ label: `认证方式：${guide.verification.label}`, level: 'required' as const, guide: guide.verification.guide }]
    : []),
];

const relatedGuides = [
  ...(needsStudentVerification ? [{ label: '学生认证准备', href: '/verification/' }] : []),
  ...requirements
    .filter((item) => item.guide)
    .map((item) => ({ label: item.label.replace(/^学校/, '').replace(/^当前/, ''), href: item.guide as string })),
  ...(guide.verification ? [{ label: `${guide.verification.label} 说明`, href: guide.verification.guide }] : []),
].filter((item, index, items) => items.findIndex((candidate) => candidate.href === item.href) === index).slice(0, 4);

const benefitIcon = (name: string) => {
  const normalized = name.toLowerCase();
  if (normalized.includes('github')) {
    return `<svg viewBox="0 0 48 48" aria-hidden="true"><circle cx="24" cy="24" r="22" fill="#050505"/><path fill="#fff" d="M24 11.2c-7.2 0-13 5.8-13 13 0 5.7 3.7 10.6 8.9 12.3.7.1.9-.3.9-.7v-2.5c-3.6.8-4.4-1.5-4.4-1.5-.6-1.5-1.4-1.9-1.4-1.9-1.2-.8.1-.8.1-.8 1.3.1 2 1.3 2 1.3 1.2 2 3 1.4 3.8 1.1.1-.8.5-1.4.9-1.7-2.9-.3-5.9-1.4-5.9-6.4 0-1.4.5-2.6 1.3-3.5-.1-.3-.6-1.7.1-3.5 0 0 1.1-.4 3.6 1.3a12.5 12.5 0 0 1 6.6 0c2.5-1.7 3.6-1.3 3.6-1.3.7 1.8.3 3.2.1 3.5.8.9 1.3 2.1 1.3 3.5 0 5-3 6.1-5.9 6.4.5.4.9 1.2.9 2.4v3.6c0 .5.3.8.9.7A13 13 0 0 0 37 24.2c0-7.2-5.8-13-13-13Z"/></svg>`;
  }
  if (normalized.includes('jetbrains')) {
    return `<svg viewBox="0 0 48 48" aria-hidden="true"><defs><linearGradient id="jbGradient" x1="3" y1="3" x2="45" y2="45"><stop stop-color="#ff3d00"/><stop offset=".45" stop-color="#ff00a8"/><stop offset=".72" stop-color="#6d28d9"/><stop offset="1" stop-color="#26f7c7"/></linearGradient></defs><rect x="4" y="4" width="40" height="40" rx="3" fill="url(#jbGradient)"/><rect x="9" y="9" width="30" height="30" fill="#070707"/><text x="13" y="23" fill="#fff" font-size="8" font-family="Arial, sans-serif" font-weight="700">JET</text><text x="13" y="31" fill="#fff" font-size="8" font-family="Arial, sans-serif" font-weight="700">BRAINS</text><path d="M13 35h10" stroke="#fff" stroke-width="1.5"/></svg>`;
  }
  return `<svg viewBox="0 0 48 48" aria-hidden="true"><rect x="5" y="5" width="38" height="38" rx="10" fill="#eef0ff"/><path d="M24 13v22M13 24h22" stroke="#5147f5" stroke-width="3" stroke-linecap="round"/></svg>`;
};
---

<BaseLayout navMode="article" title={`${guide.title}｜GPT Discount`} description={guide.summary}>
  <main class={`deal-detail-page ${contentLabels.typeClass}`} data-content-type={guide.contentType}>
    <div class="deal-shell">
      <section class="deal-hero" aria-labelledby="deal-title">
        <div class="hero-copy-panel">
          <h1 id="deal-title">{guide.title}</h1>
          <p class="hero-summary">{guide.summary}</p>
          <div class="hero-meta" aria-label="优惠信息">
            <span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m7 11 2-6 3 4 4-5 2 7 3 1-2 7H5l-2-7 4-1Z" /></svg>{guide.dealPrice}</span>
            <span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 20v-5m5 5V9m5 11V5m5 15V2" /></svg>难度：{guide.difficulty}</span>
            <span><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 2" /></svg>耗时：{guide.estimatedTime}</span>
          </div>
          <div class="hero-actions">
            {guide.officialUrl && <a class="primary-action" href={guide.officialUrl} target="_blank" rel="noreferrer">{officialLabel}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9 5 7 7-7 7" /></svg></a>}
            {guide.benefits.length > 0 && <a class="secondary-action" href="#benefits">{contentLabels.benefitsLink}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9 5 7 7-7 7" /></svg></a>}
          </div>
        </div>

        <aside class={`eligibility-card ${statusClass}`} aria-label="申请资格">
          <div class="eligibility-status"><span class="status-check" aria-hidden="true">{guide.status === '可领取' ? '✓' : guide.status === '已失效' ? '×' : '!'}</span><strong>{guide.status === '可领取' ? '当前可用' : guide.status}</strong></div>
          <div class="eligibility-list">
            <div><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="8" r="4" /><path d="M4 21a8 8 0 0 1 16 0" /></svg><span>适用人群：{guide.audience}</span></div>
            <div><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m3 9 9-5 9 5-9 5-9-5Z" /><path d="M7 12v5c3 2 7 2 10 0v-5" /></svg><span>内容类型：{guide.contentType}</span></div>
            <div><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12 2.2 2.2 4.8-5"/></svg><span>核验记录：{verificationDetails}</span></div>
            {guide.officialUrl && <a href={guide.officialUrl} target="_blank" rel="noreferrer"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 4h6v6M20 4 10 14" /><path d="M18 13v6a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1h6" /></svg><span>官方入口：<b>{officialLabel}</b></span></a>}
          </div>
        </aside>
      </section>

      {guide.benefits.length > 0 && <section class="benefits-section" id="benefits" aria-labelledby="benefits-title">
        <div class="section-heading"><h2 id="benefits-title">{contentLabels.benefits}</h2>{guide.allBenefitsUrl && <a href={guide.allBenefitsUrl} target="_blank" rel="noreferrer">查看官方说明<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14m-5-5 5 5-5 5" /></svg></a>}</div>
        <div class="benefit-grid">{guide.benefits.map((benefit) => <article class="benefit-card"><span class="benefit-logo" set:html={benefitIcon(benefit.name)}></span><div><strong>{benefit.name}</strong><p>{benefit.value}</p></div>{benefit.type === 'limited' && <small>有限制</small>}</article>)}</div>
      </section>}

      {guide.comparisonOptions.length > 0 && <section class="comparison-section" id="comparison" aria-labelledby="comparison-title">
        <div class="section-heading comparison-heading">
          <div>
            <h2 id="comparison-title">卡片与认证要求对比</h2>
            <p>先看你能否合法开户，再比较费用和商户兼容性；“有卡号”不等于一定能通过订阅风控。</p>
          </div>
        </div>
        <div class="comparison-table" role="table" aria-label="卡片方案对比">
          <div class="comparison-row comparison-header" role="row">
            <span role="columnheader">方案 / 类型</span>
            <span role="columnheader">大陆用户</span>
            <span role="columnheader">认证要求</span>
            <span role="columnheader">费用</span>
            <span role="columnheader">适合用途</span>
            <span role="columnheader">注意事项</span>
          </div>
          {guide.comparisonOptions.map((option) => (
            <div class="comparison-row" role="row">
              <div class="comparison-name" role="cell" data-label="方案 / 类型">
                <strong>{option.name}</strong>
                <small>{option.cardType}</small>
                {option.officialUrl && <a href={option.officialUrl} target="_blank" rel="noreferrer">官方说明 ↗</a>}
              </div>
              <div role="cell" data-label="大陆用户">{option.availability}</div>
              <div role="cell" data-label="认证要求">{option.verification}</div>
              <div role="cell" data-label="费用">{option.cost}</div>
              <div role="cell" data-label="适合用途">{option.bestFor}</div>
              <div role="cell" data-label="注意事项">{option.caution}</div>
            </div>
          ))}
        </div>
      </section>}

      <div class="content-grid">
        <section class="detail-panel requirements-panel" aria-labelledby="requirements-title">
          <h2 id="requirements-title">{contentLabels.requirements}</h2>
          <div class="condition-list">
            {conditionItems.map((item) => item.guide ? (
              <a href={item.guide}>
                <span class="condition-check" aria-hidden="true">✓</span>
                <span class="condition-copy"><strong>{item.label}</strong><small>{item.level === 'recommended' ? '建议准备' : '必须满足'} · 查看说明 →</small></span>
                <svg class="row-arrow" viewBox="0 0 24 24" aria-hidden="true"><path d="m9 5 7 7-7 7" /></svg>
              </a>
            ) : (
              <div>
                <span class="condition-check" aria-hidden="true">✓</span>
                <span class="condition-copy"><strong>{item.label}</strong><small>{item.level === 'recommended' ? '建议准备' : '必须满足'}</small></span>
              </div>
            ))}
          </div>
          {relatedGuides.length > 0 && <div class="related-guides"><h3>相关页面</h3><div class="related-guide-grid">{relatedGuides.map((item) => <a href={item.href}><span class="related-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 5.5A3.5 3.5 0 0 1 7.5 2H11v17H7.5A3.5 3.5 0 0 0 4 22V5.5ZM20 5.5A3.5 3.5 0 0 0 16.5 2H13v17h3.5A3.5 3.5 0 0 1 20 22V5.5Z" /></svg></span><span>{item.label}</span></a>)}</div></div>}
        </section>

        <section class="detail-panel steps-panel" id="steps" aria-labelledby="steps-title">
          <h2 id="steps-title">{contentLabels.steps}</h2>
          <ol class="step-list">{guide.steps.map((step, index) => <li><span class="step-number">{index + 1}</span><div class="step-copy"><h3>{step.title}</h3><p>{step.description}</p>{step.note && <small>{step.note}</small>}</div></li>)}</ol>
        </section>
      </div>

      {(guide.faq.length > 0 || guide.warning) && <section class="faq-panel" aria-labelledby="faq-title">
        <h2 id="faq-title">{contentLabels.faq}</h2>
        <div class="faq-list">
          {guide.faq.map((item) => <details><summary><strong>{item.question}</strong><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m7 9 5 5 5-5" /></svg></summary><p>{item.answer}</p></details>)}
          {guide.warning && <details><summary><strong>{contentLabels.warning}</strong><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m7 9 5 5 5-5" /></svg></summary><p>{guide.warning}</p></details>}
        </div>
      </section>}
    </div>
    {guide.officialUrl && <div class="mobile-apply-bar"><a href={guide.officialUrl} target="_blank" rel="noreferrer">{officialLabel}</a></div>}
  </main>

  <style is:global>
    .condition-list > div { grid-template-columns: 25px minmax(0, 1fr); }
    .step-list li { grid-template-columns: 52px minmax(0, 1fr); }
    .faq-list summary { grid-template-columns: minmax(0, 1fr) 20px; gap: 16px; }
    .faq-list summary svg { justify-self: end; }
    .faq-list details[open] > p { display: block; padding: 0 16px 16px; }

    .comparison-section {
      margin: 28px 0;
      padding: 28px;
      border: 1px solid #e8e8ef;
      border-radius: 24px;
      background: #fff;
      box-shadow: 0 16px 42px rgba(28, 25, 61, 0.05);
    }

    .comparison-heading p {
      max-width: 760px;
      margin: 8px 0 0;
      color: #646477;
      line-height: 1.7;
    }

    .comparison-table {
      margin-top: 20px;
      overflow: hidden;
      border: 1px solid #e9e9f1;
      border-radius: 16px;
    }

    .comparison-row {
      display: grid;
      grid-template-columns: minmax(150px, 1.05fr) minmax(125px, .9fr) minmax(180px, 1.35fr) minmax(130px, .9fr) minmax(155px, 1.1fr) minmax(170px, 1.25fr);
      border-top: 1px solid #ececf3;
      background: #fff;
    }

    .comparison-row:first-child { border-top: 0; }

    .comparison-row > * {
      min-width: 0;
      padding: 16px 14px;
      border-left: 1px solid #ececf3;
      color: #3f3f4f;
      font-size: 13px;
      line-height: 1.55;
      overflow-wrap: anywhere;
    }

    .comparison-row > *:first-child { border-left: 0; }
    .comparison-header { background: #f7f7fb; }

    .comparison-header > * {
      color: #55556b;
      font-size: 12px;
      font-weight: 700;
    }

    .comparison-name {
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    .comparison-name strong { color: #20202b; font-size: 14px; }
    .comparison-name small { color: #77778a; }

    .comparison-name a {
      width: fit-content;
      color: #5147f5;
      font-size: 12px;
      font-weight: 700;
      text-decoration: none;
    }

    @media (max-width: 980px) {
      .comparison-section { padding: 20px; }
      .comparison-table { border: 0; overflow: visible; }
      .comparison-header { display: none; }
      .comparison-row {
        display: block;
        margin-top: 14px;
        border: 1px solid #e7e7ef;
        border-radius: 16px;
        overflow: hidden;
      }
      .comparison-row:first-child + .comparison-row { margin-top: 0; }
      .comparison-row > * {
        display: grid;
        grid-template-columns: 92px minmax(0, 1fr);
        gap: 12px;
        border: 0;
        border-top: 1px solid #eeeef4;
        padding: 12px 14px;
      }
      .comparison-row > *:first-child { border-top: 0; }
      .comparison-row > *::before {
        content: attr(data-label);
        color: #77778a;
        font-size: 12px;
        font-weight: 700;
      }
      .comparison-name { display: grid; grid-template-columns: 92px minmax(0, 1fr); }
      .comparison-name strong,
      .comparison-name small,
      .comparison-name a { grid-column: 2; }
      .comparison-name::before { grid-row: 1 / span 3; }
    }

    @media (max-width: 520px) {
      .step-list li { grid-template-columns: 44px minmax(0, 1fr); }
      .comparison-section { margin-inline: -4px; padding: 16px; border-radius: 20px; }
      .comparison-row > * { grid-template-columns: 78px minmax(0, 1fr); }
      .comparison-name { grid-template-columns: 78px minmax(0, 1fr); }
    }
  </style>
</BaseLayout>
