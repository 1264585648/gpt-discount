---
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getGuides } from '../../data/guides';

export async function getStaticPaths() {
  const guides = await getGuides();

  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content } = await render(guide.entry);
const conditions = guide.preparation.slice(0, 4);
---

<BaseLayout
  navMode="article"
  title={`${guide.title}｜GPT Discount`}
  description={guide.summary}
>
  <main class="compact-guide-page">
    <section class="compact-hero">
      <div class="shell">
        <div class="compact-breadcrumb">
          <a href="/">首页</a>
          <span>/</span>
          <a href={`/#${guide.categorySlug}`}>{guide.category}</a>
        </div>

        <div class="compact-title-card">
          <div class="compact-badges">
            <span class="badge brand">{guide.category}</span>
            <span class="badge success">{guide.status}</span>
            <span class={guide.contentStatus === '已完成' ? 'badge success' : 'badge warning'}>{guide.contentStatus}</span>
          </div>

          <div class="compact-heading-row">
            <div>
              <h1>{guide.title}</h1>
              <p>{guide.summary}</p>
            </div>
            <div class="compact-price">
              <span>优惠结果</span>
              <strong>{guide.dealPrice}</strong>
            </div>
          </div>

          <div class="compact-facts" aria-label="领取信息">
            <div><span>领取条件</span><strong>{guide.audience}</strong></div>
            <div><span>难度</span><strong>{guide.difficulty}</strong></div>
            <div><span>耗时</span><strong>{guide.estimatedTime}</strong></div>
            <div><span>最后核验</span><strong>{guide.lastVerified}</strong></div>
          </div>
        </div>
      </div>
    </section>

    <section class="shell compact-guide-layout">
      <div class="compact-board">
        <section class="compact-card condition-card">
          <div class="compact-section-head">
            <span>01</span>
            <h2>领取条件</h2>
          </div>
          <ul class="condition-list">
            {conditions.map((item) => <li>{item}</li>)}
          </ul>
          <div class="compact-warning">{guide.warning}</div>
        </section>

        <section class="compact-card compact-steps-card" id="steps">
          <div class="compact-section-head">
            <span>02</span>
            <h2>领取步骤</h2>
          </div>
          <div class="compact-steps-grid">
            {guide.steps.map((step, index) => (
              <article class="compact-step">
                <span class="compact-step-number">{index + 1}</span>
                <div>
                  <h3>{step.title}</h3>
                  <p>{step.description}</p>
                  {step.note && <small>{step.note}</small>}
                </div>
              </article>
            ))}
          </div>
        </section>
      </div>

      <div class="compact-extras">
        <details class="compact-detail-card">
          <summary>失败排查</summary>
          <div class="compact-faq-list">
            {guide.faq.map((item) => (
              <details>
                <summary>{item.question}</summary>
                <p>{item.answer}</p>
              </details>
            ))}
          </div>
        </details>

        <details class="compact-detail-card">
          <summary>补充说明与官方来源</summary>
          <div class="compact-markdown"><Content /></div>
        </details>
      </div>
    </section>
  </main>

  <style>
    .compact-guide-page {
      min-height: calc(100vh - 72px);
    }

    .compact-hero {
      padding: 18px 0 10px;
    }

    .compact-breadcrumb {
      display: flex;
      align-items: center;
      gap: 7px;
      margin-bottom: 10px;
      color: var(--muted);
      font-size: 13px;
    }

    .compact-title-card,
    .compact-card,
    .compact-detail-card {
      border: 1px solid rgba(255, 255, 255, 0.92);
      background: rgba(255, 255, 255, 0.9);
      box-shadow: var(--shadow-soft);
    }

    .compact-title-card {
      padding: 18px 22px;
      border-radius: 22px;
    }

    .compact-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
      margin-bottom: 10px;
    }

    .compact-heading-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(220px, 300px);
      align-items: end;
      gap: 24px;
    }

    .compact-heading-row h1 {
      margin: 0;
      font-size: clamp(28px, 4vw, 42px);
      line-height: 1.08;
      letter-spacing: -0.055em;
    }

    .compact-heading-row p {
      margin: 8px 0 0;
      max-width: 760px;
      color: var(--muted);
      font-size: 15px;
      line-height: 1.55;
    }

    .compact-price {
      padding: 12px 14px;
      border: 1px solid rgba(79, 70, 229, 0.14);
      border-radius: 16px;
      background: var(--brand-soft);
    }

    .compact-price span,
    .compact-facts span {
      display: block;
      color: var(--subtle);
      font-size: 11px;
      font-weight: 700;
    }

    .compact-price strong {
      display: block;
      margin-top: 3px;
      color: var(--brand-strong);
      font-size: 15px;
      line-height: 1.35;
    }

    .compact-facts {
      display: grid;
      grid-template-columns: 1.4fr .65fr .8fr .75fr;
      gap: 8px;
      margin-top: 14px;
    }

    .compact-facts > div {
      min-width: 0;
      padding: 9px 11px;
      border: 1px solid var(--line);
      border-radius: 13px;
      background: #f8fafc;
    }

    .compact-facts strong {
      display: block;
      margin-top: 2px;
      font-size: 13px;
      line-height: 1.35;
      overflow-wrap: anywhere;
    }

    .compact-guide-layout {
      padding: 0 0 42px;
    }

    .compact-board {
      display: grid;
      grid-template-columns: minmax(250px, .72fr) minmax(0, 1.75fr);
      gap: 12px;
      align-items: stretch;
    }

    .compact-card {
      min-width: 0;
      padding: 16px;
      border-radius: 20px;
    }

    .compact-section-head {
      display: flex;
      align-items: center;
      gap: 9px;
      margin-bottom: 12px;
    }

    .compact-section-head > span {
      width: 28px;
      height: 28px;
      display: grid;
      place-items: center;
      flex: 0 0 auto;
      border-radius: 9px;
      color: #fff;
      background: var(--brand);
      font-size: 11px;
      font-weight: 900;
    }

    .compact-section-head h2 {
      margin: 0;
      font-size: 20px;
      line-height: 1.2;
      letter-spacing: -0.035em;
    }

    .condition-list {
      display: grid;
      gap: 8px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .condition-list li {
      position: relative;
      padding: 9px 10px 9px 30px;
      border: 1px solid var(--line);
      border-radius: 13px;
      background: #f8fafc;
      color: #344054;
      font-size: 13px;
      line-height: 1.4;
    }

    .condition-list li::before {
      content: '✓';
      position: absolute;
      left: 10px;
      top: 9px;
      color: var(--success);
      font-weight: 900;
    }

    .compact-warning {
      margin-top: 10px;
      padding: 10px 11px;
      border: 1px solid rgba(217, 119, 6, .15);
      border-radius: 13px;
      background: var(--warning-soft);
      color: #7a4b00;
      font-size: 12px;
      line-height: 1.45;
    }

    .compact-steps-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
    }

    .compact-step {
      min-width: 0;
      display: grid;
      grid-template-columns: 28px minmax(0, 1fr);
      gap: 9px;
      padding: 10px;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: linear-gradient(180deg, #fff, #fbfcff);
    }

    .compact-step-number {
      width: 28px;
      height: 28px;
      display: grid;
      place-items: center;
      border-radius: 9px;
      color: #fff;
      background: linear-gradient(135deg, var(--brand), #0ea5e9);
      font-size: 12px;
      font-weight: 900;
    }

    .compact-step h3 {
      margin: 1px 0 4px;
      font-size: 14px;
      line-height: 1.3;
    }

    .compact-step p {
      margin: 0;
      color: #475467;
      font-size: 12px;
      line-height: 1.45;
    }

    .compact-step small {
      display: block;
      margin-top: 5px;
      color: #8a5800;
      font-size: 11px;
      line-height: 1.4;
    }

    .compact-extras {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin-top: 10px;
    }

    .compact-detail-card {
      min-width: 0;
      padding: 0 15px;
      border-radius: 16px;
    }

    .compact-detail-card > summary,
    .compact-faq-list summary {
      cursor: pointer;
      font-weight: 800;
    }

    .compact-detail-card > summary {
      padding: 13px 0;
      font-size: 14px;
    }

    .compact-faq-list,
    .compact-markdown {
      padding: 0 0 14px;
    }

    .compact-faq-list details {
      padding: 8px 0;
      border-top: 1px solid var(--line);
    }

    .compact-faq-list summary {
      font-size: 13px;
    }

    .compact-faq-list p,
    .compact-markdown :global(p),
    .compact-markdown :global(li) {
      color: #475467;
      font-size: 13px;
      line-height: 1.55;
    }

    .compact-markdown :global(h2) {
      margin: 12px 0 6px;
      font-size: 16px;
    }

    .compact-markdown :global(h2:first-child) {
      margin-top: 0;
    }

    @media (max-width: 900px) {
      .compact-heading-row,
      .compact-board {
        grid-template-columns: 1fr;
      }

      .compact-price {
        display: none;
      }
    }

    @media (max-width: 640px) {
      .compact-hero {
        padding-top: 10px;
      }

      .compact-title-card {
        padding: 15px;
        border-radius: 18px;
      }

      .compact-heading-row h1 {
        font-size: 28px;
      }

      .compact-heading-row p {
        font-size: 14px;
      }

      .compact-facts {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .compact-board,
      .compact-extras {
        grid-template-columns: 1fr;
      }

      .compact-steps-grid {
        grid-template-columns: 1fr;
      }

      .compact-card {
        padding: 14px;
        border-radius: 18px;
      }
    }
  </style>
</BaseLayout>
