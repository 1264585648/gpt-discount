---
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import StepCard from '../../components/StepCard.astro';
import DealSidebar from '../../components/DealSidebar.astro';
import { getGuides } from '../../data/guides';

export async function getStaticPaths() {
  const guides = await getGuides();

  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content } = await render(guide.entry);
---

<BaseLayout
  navMode="article"
  title={`${guide.title}｜GPT Discount`}
  description={guide.summary}
>
  <main class="article-page">
    <section class="article-hero pro-article-hero">
      <div class="shell article-hero-shell">
        <div class="breadcrumb">
          <a href="/">首页</a>
          <span>/</span>
          <a href={`/#${guide.categorySlug}`}>{guide.category}</a>
          <span>/</span>
          <span>{guide.title}</span>
        </div>

        <div class="article-title-card pro-article-title-card">
          <div class="badges">
            <span class="badge brand">{guide.category}</span>
            <span class="badge success">{guide.status}</span>
            <span class={guide.contentStatus === '已完成' ? 'badge success' : 'badge warning'}>{guide.contentStatus}</span>
            <span class="badge">{guide.estimatedTime}</span>
          </div>
          <h1>{guide.title}</h1>
          <p class="article-lead">{guide.summary}</p>

          <div class="article-quick-grid" aria-label="优惠关键判断">
            <div><span>适合人群</span><strong>{guide.audience}</strong></div>
            <div><span>操作难度</span><strong>{guide.difficulty}</strong></div>
            <div><span>优惠类型</span><strong>{guide.dealType}</strong></div>
            <div><span>最后验证</span><strong>{guide.lastVerified}</strong></div>
          </div>
        </div>
      </div>
    </section>

    <section class="shell article-layout pro-article-layout">
      <article class="article-main pro-article-main">
        <section class="article-card reading-card overview-card" id="overview">
          <span class="section-step">01</span>
          <h2>先判断：你能不能领、值不值得领</h2>
          <p>不要一上来就点领取入口。先确认邮箱、地区、身份、套餐、付款方式和续费规则，避免最后一步才发现不符合条件。</p>
          <div class="info-grid pro-info-grid">
            <div class="info-tile"><span>优惠类型</span><strong>{guide.dealType}</strong></div>
            <div class="info-tile"><span>预计耗时</span><strong>{guide.estimatedTime}</strong></div>
            <div class="info-tile"><span>操作难度</span><strong>{guide.difficulty}</strong></div>
            <div class="info-tile"><span>适合人群</span><strong>{guide.audience}</strong></div>
          </div>
        </section>

        <section class="article-card reading-card prepare-card" id="prepare">
          <span class="section-step">02</span>
          <h2>领取前准备</h2>
          <p>正式操作前，先把下面这些信息准备好。能提前确认的内容越多，后面遇到验证失败、价格不一致或付款被拒的概率越低。</p>
          <ul class="check-list">
            {guide.preparation.map((item) => <li>{item}</li>)}
          </ul>
          <div class="callout">建议先看完「常见失败原因」再开始操作，尤其是涉及教育认证、地区限制、云服务账单和自动续费的优惠。</div>
        </section>

        <section class="article-card reading-card steps-card" id="steps">
          <span class="section-step">03</span>
          <h2>详细领取步骤</h2>
          <p>按顺序操作。遇到页面文案、价格或验证方式变化时，先停下来核对本篇的失败排查和官方说明，不要急着反复提交。</p>
          <div class="step-list pro-step-list">
            {guide.steps.map((step, index) => <StepCard step={step} index={index} />)}
          </div>
        </section>

        <section class="article-card reading-card faq-card" id="faq">
          <span class="section-step">04</span>
          <h2>常见失败原因</h2>
          <div class="faq-list">
            {guide.faq.map((item) => (
              <details class="faq-item">
                <summary>{item.question}</summary>
                <p>{item.answer}</p>
              </details>
            ))}
          </div>
        </section>

        <section class="article-card reading-card markdown-content pro-markdown" id="article-body">
          <span class="section-step">05</span>
          <Content />
        </section>

        <section class="article-card reading-card editor-note-card">
          <span class="section-step">提醒</span>
          <h2>补充提醒</h2>
          <p>{guide.editorNote}</p>
        </section>
      </article>

      <DealSidebar guide={guide} />
    </section>
  </main>

  <div class="mobile-action-bar" aria-label="移动端操作栏">
    <button class="btn" type="button" data-copy="#coupon-code">复制优惠码</button>
    <a class="btn btn-primary" href="#steps">看领取步骤</a>
  </div>

  <script is:inline>
    document.querySelectorAll('[data-copy]').forEach((button) => {
      button.addEventListener('click', async () => {
        const targetSelector = button.getAttribute('data-copy');
        const target = document.querySelector(targetSelector);
        const text = target?.textContent?.trim();
        if (!text) return;

        try {
          await navigator.clipboard.writeText(text);
          const original = button.textContent;
          button.textContent = '已复制';
          setTimeout(() => { button.textContent = original; }, 1400);
        } catch (error) {
          button.textContent = '复制失败';
        }
      });
    });
  </script>
</BaseLayout>
