---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getGuides } from '../../data/guides';

export async function getStaticPaths() {
  const guides = await getGuides();

  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;
---

<BaseLayout
  navMode="article"
  title={`${guide.title}｜GPT Discount`}
  description={guide.summary}
>
  <main class="quick-guide">
    <div class="shell quick-shell">
      <a class="quick-back" href="/">← 返回</a>

      <header class="quick-header">
        <div class="quick-title">
          <h1>{guide.title}</h1>
          <strong>{guide.dealPrice}</strong>
        </div>

        <div class="quick-meta">
          <div><span>条件</span><b>{guide.audience}</b></div>
          <div><span>难度</span><b>{guide.difficulty}</b></div>
          <div><span>耗时</span><b>{guide.estimatedTime}</b></div>
        </div>

        {guide.officialUrl && (
          <a class="quick-apply" href={guide.officialUrl} target="_blank" rel="noreferrer">
            打开申请页
          </a>
        )}
      </header>

      <div class="quick-grid">
        <section class="quick-card quick-conditions">
          <h2>领取条件</h2>
          <ul>
            {guide.preparation.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="quick-card quick-steps" id="steps">
          <h2>操作步骤</h2>
          <ol>
            {guide.steps.map((step) => (
              <li>
                <div>
                  <h3>{step.title}</h3>
                  <p>{step.description}</p>
                </div>
              </li>
            ))}
          </ol>
        </section>
      </div>

      {(guide.faq.length > 0 || guide.warning) && (
        <details class="quick-help">
          <summary>遇到问题</summary>
          <div class="quick-help-grid">
            {guide.faq.map((item) => (
              <div>
                <b>{item.question}</b>
                <span>{item.answer}</span>
              </div>
            ))}
            {guide.warning && (
              <div>
                <b>注意</b>
                <span>{guide.warning}</span>
              </div>
            )}
          </div>
        </details>
      )}
    </div>
  </main>

  <style>
    .quick-guide {
      min-height: calc(100vh - 132px);
      padding: 18px 0 28px;
    }

    .quick-shell {
      max-width: 1040px;
    }

    .quick-back {
      display: inline-block;
      margin-bottom: 12px;
      color: var(--muted);
      font-size: 13px;
    }

    .quick-header,
    .quick-card,
    .quick-help {
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, .94);
      box-shadow: 0 8px 24px rgba(15, 23, 42, .06);
    }

    .quick-header {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto auto;
      align-items: center;
      gap: 22px;
      padding: 20px 22px;
      border-radius: 18px;
    }

    .quick-title h1 {
      margin: 0;
      font-size: clamp(28px, 4vw, 40px);
      line-height: 1.05;
      letter-spacing: -.055em;
    }

    .quick-title strong {
      display: block;
      margin-top: 7px;
      color: var(--success);
      font-size: 14px;
    }

    .quick-meta {
      display: flex;
      gap: 18px;
    }

    .quick-meta div {
      min-width: 70px;
    }

    .quick-meta span,
    .quick-meta b {
      display: block;
    }

    .quick-meta span {
      color: var(--subtle);
      font-size: 11px;
    }

    .quick-meta b {
      margin-top: 2px;
      font-size: 13px;
      line-height: 1.3;
    }

    .quick-apply {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 42px;
      padding: 0 18px;
      border-radius: 12px;
      color: #fff;
      background: var(--brand);
      font-size: 14px;
      font-weight: 800;
      white-space: nowrap;
    }

    .quick-grid {
      display: grid;
      grid-template-columns: minmax(250px, .72fr) minmax(0, 1.55fr);
      gap: 12px;
      margin-top: 12px;
    }

    .quick-card {
      padding: 18px;
      border-radius: 18px;
    }

    .quick-card h2 {
      margin: 0 0 12px;
      font-size: 18px;
      line-height: 1.2;
    }

    .quick-conditions ul,
    .quick-steps ol {
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .quick-conditions ul {
      display: grid;
      gap: 8px;
    }

    .quick-conditions li {
      position: relative;
      padding: 9px 8px 9px 25px;
      border-bottom: 1px solid var(--line);
      color: #344054;
      font-size: 13px;
      line-height: 1.4;
    }

    .quick-conditions li:last-child {
      border-bottom: 0;
    }

    .quick-conditions li::before {
      content: '✓';
      position: absolute;
      left: 3px;
      color: var(--success);
      font-weight: 900;
    }

    .quick-steps ol {
      counter-reset: step;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
    }

    .quick-steps li {
      counter-increment: step;
      display: grid;
      grid-template-columns: 26px minmax(0, 1fr);
      gap: 9px;
      padding: 10px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #fafbff;
    }

    .quick-steps li::before {
      content: counter(step);
      width: 26px;
      height: 26px;
      display: grid;
      place-items: center;
      border-radius: 8px;
      color: #fff;
      background: var(--brand);
      font-size: 12px;
      font-weight: 900;
    }

    .quick-steps h3 {
      margin: 1px 0 3px;
      font-size: 14px;
      line-height: 1.3;
    }

    .quick-steps p {
      margin: 0;
      color: #475467;
      font-size: 12px;
      line-height: 1.45;
    }

    .quick-help {
      margin-top: 10px;
      padding: 0 16px;
      border-radius: 14px;
    }

    .quick-help > summary {
      padding: 12px 0;
      cursor: pointer;
      font-size: 13px;
      font-weight: 800;
    }

    .quick-help-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
      padding: 0 0 14px;
    }

    .quick-help-grid div {
      padding: 9px 10px;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: #fafbff;
    }

    .quick-help-grid b,
    .quick-help-grid span {
      display: block;
    }

    .quick-help-grid b {
      font-size: 12px;
    }

    .quick-help-grid span {
      margin-top: 3px;
      color: #475467;
      font-size: 12px;
      line-height: 1.4;
    }

    @media (max-width: 820px) {
      .quick-header {
        grid-template-columns: 1fr;
        gap: 14px;
      }

      .quick-meta {
        justify-content: space-between;
      }

      .quick-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 560px) {
      .quick-guide {
        padding-top: 10px;
      }

      .quick-header,
      .quick-card {
        padding: 15px;
        border-radius: 15px;
      }

      .quick-title h1 {
        font-size: 30px;
      }

      .quick-meta {
        gap: 10px;
      }

      .quick-meta div {
        min-width: 0;
      }

      .quick-apply {
        width: 100%;
      }

      .quick-steps ol,
      .quick-help-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
