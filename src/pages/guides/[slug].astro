---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getGuides } from '../../data/guides';

export async function getStaticPaths() {
  const guides = await getGuides();

  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const requirements = guide.requirements.length
  ? guide.requirements
  : guide.preparation.map((label) => ({ label, level: 'required' as const, guide: undefined }));
---

<BaseLayout
  navMode="article"
  title={`${guide.title}｜GPT Discount`}
  description={guide.summary}
>
  <main class="guide-page">
    <div class="shell guide-shell">
      <a class="back" href="/">← 返回</a>

      <header class="guide-head">
        <div>
          <h1>{guide.title}</h1>
          <div class="head-meta">
            <span>{guide.dealPrice}</span>
            <span>难度：{guide.difficulty}</span>
            <span>耗时：{guide.estimatedTime}</span>
          </div>
        </div>
        {guide.officialUrl && (
          <a class="apply" href={guide.officialUrl} target="_blank" rel="noreferrer">立即申请</a>
        )}
      </header>

      {guide.benefits.length > 0 && (
        <section class="benefit-section">
          <div class="section-title">
            <h2>你能获得</h2>
            {guide.allBenefitsUrl && (
              <a href={guide.allBenefitsUrl} target="_blank" rel="noreferrer">查看全部权益 →</a>
            )}
          </div>
          <div class="benefit-grid">
            {guide.benefits.map((benefit) => (
              <div class="benefit-card">
                <strong>{benefit.name}</strong>
                <span>{benefit.value}</span>
                {benefit.type === 'limited' && <small>限时权益</small>}
              </div>
            ))}
          </div>
        </section>
      )}

      <div class="guide-grid">
        <section class="panel requirement-panel">
          <h2>领取条件</h2>
          <div class="requirement-list">
            {requirements.map((item) => (
              item.guide ? (
                <a href={item.guide}>
                  <span>✓</span>
                  <b>{item.label}</b>
                  <small>{item.level === 'recommended' ? '推荐' : '必需'} · 查看说明 →</small>
                </a>
              ) : (
                <div>
                  <span>✓</span>
                  <b>{item.label}</b>
                  <small>{item.level === 'recommended' ? '推荐' : '必需'}</small>
                </div>
              )
            ))}
          </div>

          {guide.verification && (
            <a class="verification-link" href={guide.verification.guide}>
              认证方式：{guide.verification.label}
              <span>查看准备 →</span>
            </a>
          )}
        </section>

        <section class="panel step-panel" id="steps">
          <h2>操作步骤</h2>
          <ol>
            {guide.steps.map((step) => (
              <li>
                <div>
                  <h3>{step.title}</h3>
                  <p>{step.description}</p>
                </div>
              </li>
            ))}
          </ol>
        </section>
      </div>

      {(guide.faq.length > 0 || guide.warning) && (
        <details class="help">
          <summary>申请失败或遇到问题</summary>
          <div class="help-grid">
            {guide.faq.map((item) => (
              <div><b>{item.question}</b><span>{item.answer}</span></div>
            ))}
            {guide.warning && <div><b>注意</b><span>{guide.warning}</span></div>}
          </div>
        </details>
      )}
    </div>
  </main>

  <style>
    .guide-page { min-height: calc(100vh - 132px); padding: 16px 0 28px; }
    .guide-shell { max-width: 1100px; }
    .back { display: inline-block; margin-bottom: 10px; color: var(--muted); font-size: 13px; }

    .guide-head,
    .benefit-section,
    .panel,
    .help {
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, .95);
      box-shadow: 0 8px 22px rgba(15, 23, 42, .05);
    }

    .guide-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      padding: 18px 20px;
      border-radius: 18px;
    }
    .guide-head h1 { margin: 0; font-size: clamp(28px, 4vw, 40px); line-height: 1.05; letter-spacing: -.055em; }
    .head-meta { display: flex; flex-wrap: wrap; gap: 8px 18px; margin-top: 9px; color: var(--muted); font-size: 13px; }
    .head-meta span:first-child { color: var(--success); font-weight: 800; }
    .apply { flex: 0 0 auto; padding: 11px 18px; border-radius: 999px; color: #fff; background: var(--brand); font-weight: 800; }

    .benefit-section { margin-top: 12px; padding: 15px; border-radius: 18px; }
    .section-title { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 10px; }
    .section-title h2, .panel h2 { margin: 0; font-size: 19px; letter-spacing: -.035em; }
    .section-title a { color: var(--brand); font-size: 13px; font-weight: 700; }
    .benefit-grid { display: grid; grid-template-columns: repeat(6, minmax(0, 1fr)); gap: 8px; }
    .benefit-card { min-width: 0; padding: 11px; border: 1px solid var(--line); border-radius: 13px; background: #f8fafc; }
    .benefit-card strong, .benefit-card span, .benefit-card small { display: block; }
    .benefit-card strong { font-size: 13px; }
    .benefit-card span { margin-top: 4px; color: #344054; font-size: 12px; line-height: 1.35; }
    .benefit-card small { margin-top: 5px; color: var(--warning); font-size: 10px; }

    .guide-grid { display: grid; grid-template-columns: minmax(260px, .8fr) minmax(0, 1.55fr); gap: 12px; margin-top: 12px; }
    .panel { min-width: 0; padding: 16px; border-radius: 18px; }
    .requirement-list { display: grid; gap: 8px; margin-top: 12px; }
    .requirement-list > a,
    .requirement-list > div {
      display: grid;
      grid-template-columns: 20px minmax(0, 1fr);
      gap: 0 8px;
      padding: 10px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #f8fafc;
    }
    .requirement-list > a:hover { border-color: rgba(79, 70, 229, .28); background: var(--brand-soft); }
    .requirement-list span { color: var(--success); font-weight: 900; }
    .requirement-list b { font-size: 13px; }
    .requirement-list small { grid-column: 2; margin-top: 2px; color: var(--muted); font-size: 11px; }
    .verification-link { display: flex; justify-content: space-between; gap: 12px; margin-top: 10px; padding: 10px 11px; border-radius: 12px; color: var(--brand-strong); background: var(--brand-soft); font-size: 12px; font-weight: 750; }

    .step-panel ol { counter-reset: steps; display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px; margin: 12px 0 0; padding: 0; list-style: none; }
    .step-panel li { counter-increment: steps; display: grid; grid-template-columns: 28px minmax(0, 1fr); gap: 9px; padding: 10px; border: 1px solid var(--line); border-radius: 13px; background: #fff; }
    .step-panel li::before { content: counter(steps); width: 28px; height: 28px; display: grid; place-items: center; border-radius: 9px; color: #fff; background: var(--brand); font-size: 12px; font-weight: 900; }
    .step-panel h3 { margin: 1px 0 4px; font-size: 14px; }
    .step-panel p { margin: 0; color: #475467; font-size: 12px; line-height: 1.45; }

    .help { margin-top: 10px; padding: 0 15px; border-radius: 15px; }
    .help > summary { padding: 12px 0; cursor: pointer; font-size: 13px; font-weight: 800; }
    .help-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px; padding-bottom: 13px; }
    .help-grid > div { padding: 9px; border: 1px solid var(--line); border-radius: 11px; background: #f8fafc; }
    .help-grid b, .help-grid span { display: block; font-size: 12px; }
    .help-grid span { margin-top: 3px; color: var(--muted); line-height: 1.45; }

    @media (max-width: 900px) {
      .benefit-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
      .guide-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 620px) {
      .guide-head { align-items: flex-start; flex-direction: column; }
      .apply { width: 100%; text-align: center; }
      .benefit-grid, .step-panel ol, .help-grid { grid-template-columns: 1fr 1fr; }
    }

    @media (max-width: 420px) {
      .benefit-grid, .step-panel ol, .help-grid { grid-template-columns: 1fr; }
    }
  </style>
</BaseLayout>
