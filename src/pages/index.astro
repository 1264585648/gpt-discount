---
import BaseLayout from '../layouts/BaseLayout.astro';
import GuideCard from '../components/GuideCard.astro';
import { categories, getGuides, guideMatchesCategory } from '../data/guides';

const allGuides = await getGuides();
const guideGroups = categories.map((category) => ({
  category,
  guides: allGuides.filter((guide) => guideMatchesCategory(guide, category.slug)),
}));
const eduGuides = allGuides.filter((guide) => guideMatchesCategory(guide, 'edu-ai-discounts'));
const latestGuides = allGuides.slice(0, 4);

const routeCards = [
  {
    title: '教育邮箱 / 学生认证',
    summary: '如果你有学校邮箱、学生身份，优先从这条路线开始，覆盖 JetBrains、GitHub Student Pack、Notion、Adobe 等。',
    examples: 'JetBrains · GitHub Student Pack · Notion',
    href: '#edu-ai-discounts',
    tag: '学生最常用',
    icon: '🎓',
  },
  {
    title: 'AI 工具订阅优惠',
    summary: '适合想低价订阅 ChatGPT、Claude、Cursor、Perplexity 等工具的用户，重点看地区、套餐和付款限制。',
    examples: 'ChatGPT · Claude · Cursor · Perplexity',
    href: '#ai-tools',
    tag: '订阅前先看',
    icon: '🤖',
  },
  {
    title: '常用软件低价方案',
    summary: '适合长期使用设计、办公、密码管理和浏览器插件的用户，领取前先比价，再看续费规则。',
    examples: '1Password · Notion · 设计办公软件',
    href: '#common-software',
    tag: '适合长期续费前比价',
    icon: '🧰',
  },
  {
    title: '云服务赠金 / 免费额度',
    summary: '想要领取 Google Cloud、Oracle Cloud 或 VPS 免费额度，先看账单、风控和扣费提醒。',
    examples: 'Google Cloud · Oracle Cloud · VPS',
    href: '#cloud-credit',
    tag: '防扣费重点看',
    icon: '☁️',
  },
];

const readingSteps = [
  {
    step: '01',
    title: '先选路线',
    description: '先按你的身份和目标进入对应专题，不用一上来就通读全站。',
  },
  {
    step: '02',
    title: '再看资格',
    description: '重点看邮箱、地区、身份、付款方式、是否会自动续费。',
  },
  {
    step: '03',
    title: '最后看步骤',
    description: '确认能领以后，再按步骤操作，遇到问题直接看失败排查。',
  },
];
---

<BaseLayout
  title="GPT Discount｜AI 工具与软件优惠领取导航"
  description="整理 AI 工具、教育邮箱、常用软件、云服务赠金等优惠领取路径。每篇文章先判断资格和风险，再给操作步骤、失败原因和替代方案。"
>
  <main class="home-page">
    <section class="home-hero">
      <div class="shell home-hero-shell">
        <div class="home-hero-grid">
          <div class="home-hero-main">
            <div class="eyebrow">公开入口 · 可复查路径 · 先判断再操作</div>
            <h1>先确认能不能领，<span>再去拿优惠</span></h1>
            <p class="hero-copy">这里不是单纯的信息堆砌，而是一份可直接使用的优惠导航。你可以先按自己的目标进入专题，再看资格判断、失败排查和具体领取步骤。</p>

            <div class="search-panel" role="search">
              <span class="search-icon">⌕</span>
              <input data-search type="search" placeholder="搜索 ChatGPT、Claude、JetBrains、GitHub 学生包、Google Cloud…" aria-label="搜索优惠教程" />
              <button class="btn btn-primary" type="button" data-search-submit>搜索优惠</button>
            </div>

            <div class="search-presets" aria-label="常用搜索">
              <button type="button" data-search-preset="教育邮箱">教育邮箱</button>
              <button type="button" data-search-preset="GitHub 学生包">GitHub 学生包</button>
              <button type="button" data-search-preset="ChatGPT">ChatGPT</button>
              <button type="button" data-search-preset="云服务">云服务赠金</button>
            </div>

            <div class="category-jump home-chip-row" aria-label="分类跳转">
              {categories.map((category) => (
                <a class="pill" href={`#${category.slug}`}>{category.icon} {category.name}</a>
              ))}
              <a class="pill" href="#latest">🆕 最近更新</a>
            </div>
          </div>

          <aside class="home-hero-side" aria-label="阅读建议">
            <div class="hero-side-head">
              <span class="mini-label">快速开始</span>
              <h2>3 步找到适合你的优惠</h2>
              <p>先找路线，再看资格，最后按步骤领取。整个站点都按这个顺序组织。</p>
            </div>

            <div class="reading-steps">
              {readingSteps.map((item) => (
                <div class="reading-step-card">
                  <span class="step-mark">{item.step}</span>
                  <div>
                    <h3>{item.title}</h3>
                    <p>{item.description}</p>
                  </div>
                </div>
              ))}
            </div>

            <div class="quick-stats hero-quick-stats">
              <div class="stat">
                <strong>{categories.length}</strong>
                <span>优惠分类</span>
              </div>
              <div class="stat">
                <strong>{allGuides.length}</strong>
                <span>可读教程</span>
              </div>
              <div class="stat">
                <strong>{eduGuides.length}</strong>
                <span>学生相关</span>
              </div>
              <div class="stat">
                <strong>公开</strong>
                <span>不收录黑卡接码</span>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="shell path-section" aria-label="按目标找优惠">
      <div class="home-section-head compact-home-head">
        <div>
          <span class="mini-label">快速开始</span>
          <h2>从这 4 条路线开始</h2>
          <p>如果你不知道先看什么，就从最接近自己需求的一条路线进入。</p>
        </div>
      </div>

      <div class="path-grid">
        {routeCards.map((route) => (
          <a class="path-card" href={route.href}>
            <div class="path-card-top">
              <span class="path-icon">{route.icon}</span>
              <span class="path-tag">{route.tag}</span>
            </div>
            <h3>{route.title}</h3>
            <p>{route.summary}</p>
            <strong>{route.examples}</strong>
            <span class="path-link">进入专题 →</span>
          </a>
        ))}
      </div>
    </section>

    <section class="shell highlight-strip" aria-label="使用方式">
      <div>
        <strong>先看资格</strong>
        <span>邮箱、地区、身份、付款方式和自动续费规则先看清。</span>
      </div>
      <div>
        <strong>再看验证</strong>
        <span>优先保留最后验证时间、成功条件和失败原因，不靠传闻判断。</span>
      </div>
      <div>
        <strong>最后再操作</strong>
        <span>确认值得领以后再按步骤做，避免做到一半才发现不符合条件。</span>
      </div>
    </section>

    <section class="main-section shell home-content-section">
      <div class="home-section-head" id="latest">
        <div>
          <span class="mini-label">近期优先看</span>
          <h2>最近值得先看的优惠</h2>
          <p>这些内容更适合先浏览：要么用户需求高，要么最容易因为资格、付款、地区或验证方式踩坑。</p>
        </div>
      </div>

      <div class="featured-guide-list home-featured-grid">
        {latestGuides.map((guide) => <GuideCard guide={guide} />)}
      </div>

      <div class="home-section-head category-overview-head">
        <div>
          <span class="mini-label">专题浏览</span>
          <h2>按优惠类型继续找</h2>
          <p>每个专题都按统一结构整理：适合谁、怎么领、容易失败在哪里、有哪些风险提醒。</p>
        </div>
      </div>

      <div class="category-stack">
        {guideGroups.map(({ category, guides }) => (
          <section class="category-surface" id={category.slug} data-category-block>
            <div class="category-surface-head">
              <div>
                <h2><span class="section-icon">{category.icon}</span>{category.name}</h2>
                <p>{category.description}</p>
              </div>
              <span class="category-count">{guides.length} 篇教程</span>
            </div>

            <div class="guide-grid home-guide-grid">
              {guides.map((guide) => <GuideCard guide={guide} />)}
            </div>
          </section>
        ))}
      </div>

      <div class="empty-state" data-empty-state>
        没有找到匹配的优惠。可以尝试搜索「教育邮箱」「JetBrains」「GitHub」「Claude」「云服务」或「赠金」。
      </div>
    </section>
  </main>

  <script is:inline>
    const searchInput = document.querySelector('[data-search]');
    const searchSubmit = document.querySelector('[data-search-submit]');
    const guideCards = Array.from(document.querySelectorAll('[data-guide-card]'));
    const categoryBlocks = Array.from(document.querySelectorAll('[data-category-block]'));
    const emptyState = document.querySelector('[data-empty-state]');
    const presetButtons = Array.from(document.querySelectorAll('[data-search-preset]'));

    function normalize(text) {
      return (text || '').toLowerCase().trim();
    }

    function scrollToResults() {
      document.querySelector('#latest')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function applySearch(value) {
      const keyword = normalize(value);
      let visibleCount = 0;

      guideCards.forEach((card) => {
        const haystack = normalize(card.dataset.searchText || card.textContent);
        const isVisible = !keyword || haystack.includes(keyword);
        card.style.display = isVisible ? '' : 'none';
        if (isVisible) visibleCount += 1;
      });

      categoryBlocks.forEach((block) => {
        const visibleCards = Array.from(block.querySelectorAll('[data-guide-card]')).filter((card) => card.style.display !== 'none');
        block.style.display = visibleCards.length ? '' : 'none';
      });

      if (emptyState) emptyState.style.display = visibleCount ? 'none' : 'block';
    }

    if (searchInput) {
      searchInput.addEventListener('input', (event) => applySearch(event.target.value));
      searchInput.addEventListener('keydown', (event) => {
        if (event.key === 'Enter') {
          applySearch(event.target.value);
          scrollToResults();
        }
      });
    }

    if (searchSubmit) {
      searchSubmit.addEventListener('click', () => {
        applySearch(searchInput?.value || '');
        scrollToResults();
      });
    }

    presetButtons.forEach((button) => {
      button.addEventListener('click', (event) => {
        const keyword = button.getAttribute('data-search-preset');
        if (!keyword || !searchInput) return;
        event.preventDefault();
        searchInput.value = keyword;
        applySearch(keyword);
        scrollToResults();
      });
    });
  </script>
</BaseLayout>
