---
import BaseLayout from '../layouts/BaseLayout.astro';
import GuideCard from '../components/GuideCard.astro';
import { categories, getGuides, guideMatchesCategory } from '../data/guides';
import '../styles/home-mobile.css';

const allGuides = await getGuides();
const guideGroups = categories.map((category) => ({
  category,
  guides: allGuides.filter((guide) => guideMatchesCategory(guide, category.slug)),
}));

const preferredLatest = [
  'github-student-pack-copilot',
  'jetbrains-idea-student-pack',
];
const latestGuides = preferredLatest
  .map((slug) => allGuides.find((guide) => guide.slug === slug))
  .filter(Boolean);

const routeCards = [
  {
    title: '学生与教育优惠',
    summary: 'GitHub、JetBrains、Notion',
    href: '#edu-ai-discounts',
    tone: 'purple',
    icon: 'graduation',
  },
  {
    title: 'AI 工具订阅',
    summary: 'ChatGPT、Claude、Cursor',
    href: '#ai-tools',
    tone: 'blue',
    icon: 'spark',
  },
  {
    title: '常用软件低价',
    summary: '设计、办公、效率工具',
    href: '#common-software',
    tone: 'orange',
    icon: 'toolbox',
  },
  {
    title: '云服务赠金',
    summary: 'Google Cloud、VPS',
    href: '#cloud-credit',
    tone: 'green',
    icon: 'cloud',
  },
];

const iconPaths = {
  graduation: '<path d="m3 10 9-5 9 5-9 5-9-5Z"/><path d="M7 12v5c3.2 2.2 6.8 2.2 10 0v-5"/><path d="M21 10v6"/>',
  spark: '<path d="m12 3 2.2 6.8L21 12l-6.8 2.2L12 21l-2.2-6.8L3 12l6.8-2.2L12 3Z"/><path d="m19 3 .7 2.3L22 6l-2.3.7L19 9l-.7-2.3L16 6l2.3-.7L19 3Z"/>',
  toolbox: '<rect x="3" y="8" width="18" height="11" rx="2"/><path d="M8 8V5h8v3M3 13h18M10 13v2h4v-2"/>',
  cloud: '<path d="M17.5 19H7a5 5 0 1 1 1-9.9A6.5 6.5 0 0 1 20.3 12"/><circle cx="18" cy="17" r="4"/><path d="M18 14.8v4.4M16.7 16.1h2.1c.8 0 .8 1.2 0 1.2h-1.6c-.8 0-.8 1.2 0 1.2h2.1"/>',
};
---

<BaseLayout
  title="GPT Discount｜AI 工具与软件优惠领取导航"
  description="按身份和目标查找 AI 工具、学生教育优惠、软件折扣和云服务赠金。先判断资格，再看领取步骤、风险提醒和失败排查。"
>
  <main class="home-mobile">
    <section class="shell mobile-hero" aria-labelledby="hero-title">
      <div class="hero-art" aria-hidden="true">
        <span class="hero-ticket"></span>
        <span class="hero-check"></span>
        <span class="hero-spark one"></span>
        <span class="hero-spark two"></span>
      </div>

      <div class="hero-inner">
        <span class="hero-eyebrow">公开入口 · 可复查路径</span>
        <h1 id="hero-title">先确认能不能领，<span>再去拿优惠</span></h1>
        <p class="hero-copy">按身份和目标找到适合你的优惠，先看资格、地区和续费规则，再按步骤领取。</p>

        <div class="hero-search" role="search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m20 20-4-4"/></svg>
          <input data-search type="search" placeholder="搜索 ChatGPT、Claude、学生包……" aria-label="搜索优惠教程" />
          <button type="button" data-search-submit aria-label="搜索">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m20 20-4-4"/></svg>
          </button>
        </div>

        <div class="hot-scroll" aria-label="热门搜索">
          {['教育邮箱','GitHub 学生包','ChatGPT','Claude','云服务赠金'].map((item) => (
            <button type="button" data-search-preset={item}>{item}</button>
          ))}
        </div>

        <div class="hero-trust" aria-label="可信数据">
          <div><strong>{categories.length}</strong><span>类优惠</span></div>
          <div><strong>{allGuides.length}</strong><span>篇教程</span></div>
          <div><strong>公开</strong><span>可核验</span></div>
        </div>
      </div>
    </section>

    <section class="shell home-section" aria-labelledby="route-title">
      <div class="section-heading">
        <div>
          <h2 id="route-title">从你的需求开始</h2>
          <p>选择最接近你的身份或目标</p>
        </div>
      </div>

      <div class="route-grid">
        {routeCards.map((route) => (
          <a class={`route-card tone-${route.tone}`} href={route.href}>
            <span class="route-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths[route.icon]} />
            </span>
            <h3>{route.title}</h3>
            <p>{route.summary}</p>
            <span class="route-arrow" aria-hidden="true">›</span>
          </a>
        ))}
      </div>
    </section>

    <section class="shell home-section" id="latest" aria-labelledby="latest-title">
      <div class="section-heading">
        <div><h2 id="latest-title">最近核验</h2></div>
        <a class="section-link" href="#all-guides">查看全部 →</a>
      </div>

      <div class="verified-list">
        {latestGuides.map((guide) => (
          <a class="verified-card" href={`/guides/${guide.slug}/`} data-guide-card data-search-text={`${guide.title} ${guide.summary} ${guide.audience} ${guide.category}`}>
            <span class={`brand-badge ${guide.slug.includes('jetbrains') ? 'jetbrains' : ''}`}>
              {guide.slug.includes('jetbrains') ? <span>JET<br/>BRAINS</span> : <span>GH</span>}
            </span>
            <span class="verified-main">
              <span class="verified-top">
                <span class="status-pill">{guide.status}</span>
                <span class="time-hint">预计 {guide.estimatedTime}</span>
              </span>
              <h3>{guide.title}</h3>
              <span class="verified-meta">
                <span class="price">{guide.dealPrice}</span>
                <span class="audience">适合：{guide.audience}</span>
                <span class="verified-date">{guide.lastVerified} 验证</span>
              </span>
            </span>
            <span class="enter-button" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </section>

    <section class="shell all-content" id="all-guides">
      <div class="section-heading">
        <div>
          <h2>继续浏览全部优惠</h2>
          <p>每篇教程都包含资格判断、领取步骤、风险提醒和失败排查。</p>
        </div>
      </div>

      <div class="category-stack">
        {guideGroups.map(({ category, guides }) => (
          <section class="category-surface" id={category.slug} data-category-block>
            <div class="category-surface-head">
              <div>
                <h2>{category.name}</h2>
                <p>{category.description}</p>
              </div>
              <span class="category-count">{guides.length} 篇教程</span>
            </div>
            <div class="home-guide-grid">
              {guides.map((guide) => <GuideCard guide={guide} />)}
            </div>
          </section>
        ))}
      </div>

      <div class="empty-state" data-empty-state>没有找到匹配的优惠，可以尝试搜索「教育邮箱」「GitHub」「Claude」或「云服务」。</div>
    </section>
  </main>

  <script is:inline>
    const searchInput = document.querySelector('[data-search]');
    const searchSubmit = document.querySelector('[data-search-submit]');
    const guideCards = Array.from(document.querySelectorAll('[data-guide-card]'));
    const categoryBlocks = Array.from(document.querySelectorAll('[data-category-block]'));
    const emptyState = document.querySelector('[data-empty-state]');
    const presets = Array.from(document.querySelectorAll('[data-search-preset]'));
    const normalize = (text) => (text || '').toLowerCase().trim();

    function applySearch(value) {
      const keyword = normalize(value);
      let visible = 0;
      guideCards.forEach((card) => {
        const matched = !keyword || normalize(card.dataset.searchText || card.textContent).includes(keyword);
        card.style.display = matched ? '' : 'none';
        if (matched) visible += 1;
      });
      categoryBlocks.forEach((block) => {
        const shown = Array.from(block.querySelectorAll('[data-guide-card]')).some((card) => card.style.display !== 'none');
        block.style.display = shown ? '' : 'none';
      });
      if (emptyState) emptyState.style.display = visible ? 'none' : 'block';
    }

    function submitSearch() {
      applySearch(searchInput?.value || '');
      document.querySelector('#all-guides')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    searchInput?.addEventListener('input', (event) => applySearch(event.target.value));
    searchInput?.addEventListener('keydown', (event) => event.key === 'Enter' && submitSearch());
    searchSubmit?.addEventListener('click', submitSearch);
    presets.forEach((button) => button.addEventListener('click', () => {
      if (!searchInput) return;
      searchInput.value = button.dataset.searchPreset || '';
      submitSearch();
    }));
  </script>
</BaseLayout>