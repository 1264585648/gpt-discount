---
import type { GuideStep } from '../data/guides';

interface Props {
  step: GuideStep;
  index: number;
}

const { step, index } = Astro.props;
---

<div class="step-card pro-step-card">
  <div class="step-number-wrap">
    <div class="step-number">{index + 1}</div>
    <span>Step</span>
  </div>
  <div class="step-content">
    <h3>{step.title}</h3>
    <p>{step.description}</p>
    {step.note && <div class="step-note">{step.note}</div>}
    {step.imageLabel && <div class="mock-shot"><span>操作参考</span><strong>{step.imageLabel}</strong></div>}
  </div>
</div>
