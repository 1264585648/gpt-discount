---
import type { Guide } from '../data/guides';
import { getGuideBrand, getGuidePresentationCategory } from '../data/guides';

interface Props {
  guide: Guide;
  initiallyHidden?: boolean;
  defaultOrder?: number;
}

const { guide, initiallyHidden = false, defaultOrder = 0 } = Astro.props;
const category = getGuidePresentationCategory(guide);

const presentationStatus = () => {
  if (guide.status === '已失效') return { label: '已结束', className: 'expired', cta: '查看历史信息' };
  if (guide.status === '待验证') return { label: '待验证', className: 'pending', cta: '查看当前信息' };
  if (category === '学校授权') return { label: '需学校授权', className: 'school', cta: '查看申请步骤' };
  if (category === '学生优惠') return { label: '需学生认证', className: 'student', cta: '查看申请步骤' };
  if (category === '限时活动') return { label: '限时活动', className: 'limited', cta: '查看领取教程' };
  if (category === '地区限制') return { label: '部分地区可用', className: 'regional', cta: '查看适用地区' };
  return { label: '可领取', className: 'available', cta: '查看领取教程' };
};

const status = presentationStatus();
const brand = getGuideBrand(guide);
const benefits = [...new Set([
  ...(guide.benefits ?? []).map((item) => item.value),
  guide.dealPrice,
  guide.dealType,
].filter(Boolean))].slice(0, 3);
const verifiedText = guide.status === '待验证' ? '尚未核验' : `${guide.lastVerified} 核验`;
---

<article
  class:list={['topic-deal-row', `is-${status.className}`, { 'is-initially-hidden': initiallyHidden }]}
  data-deal-card
  data-category={category}
  data-title={guide.title}
  data-verified={guide.lastVerified}
  data-default-order={defaultOrder}
>
  <div class={`deal-brand-mark is-${brand.className}`} aria-hidden="true">{brand.label}</div>

  <div class="deal-summary">
    <div class="deal-title-line">
      <h3>{guide.title}</h3>
      <span class={`deal-status is-${status.className}`}>{status.label}</span>
    </div>
    <p>{guide.summary}</p>
    <div class="deal-meta" aria-label="优惠信息">
      <span><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="8" r="3"/><path d="M6 20c.5-4 2.5-6 6-6s5.5 2 6 6"/></svg>{guide.audience}</span>
      <span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3 20 6v6c0 5-3.4 8-8 9-4.6-1-8-4-8-9V6l8-3Z"/><path d="m8.5 12 2.2 2.2 4.8-5"/></svg>{guide.regionLabel ?? guide.region}</span>
      <span><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>{verifiedText}</span>
    </div>
  </div>

  <div class="deal-benefits">
    <span class="deal-column-label">主要权益</span>
    <ul>
      {benefits.map((benefit) => <li><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m5 12 4 4L19 6"/></svg><span>{benefit}</span></li>)}
    </ul>
  </div>

  <div class="deal-actions">
    <a class="deal-primary-action" href={`/guides/${guide.slug}/`}>
      {status.cta}
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6"/></svg>
    </a>
    {guide.officialUrl ? (
      <a class="deal-secondary-action" href={guide.officialUrl} target="_blank" rel="noreferrer">
        官方页面
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 5h5v5M13 11l6-6M19 13v6H5V5h6"/></svg>
      </a>
    ) : (
      <span class="deal-secondary-note">{guide.warning}</span>
    )}
  </div>
</article>

<style>
  .badge.danger {
    color: #b42318;
    background: #fff1f0;
    border-color: rgba(180, 35, 24, .18);
  }

  .offer-badge {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 5px 11px;
    color: #fff;
    font-size: 12px;
    font-weight: 900;
    line-height: 1;
    letter-spacing: .04em;
    border-radius: 999px;
    box-shadow: 0 6px 16px rgba(15, 23, 42, .12);
  }

  .offer-summary {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 14px;
    align-items: center;
    margin-top: 18px;
    padding: 14px 16px;
    border: 1px solid rgba(15, 159, 110, .2);
    border-radius: 18px;
    background: #effcf6;
  }

  .offer-summary-label {
    min-width: 68px;
    min-height: 42px;
    display: grid;
    place-items: center;
    padding: 0 10px;
    color: #fff;
    font-size: 14px;
    font-weight: 900;
    border-radius: 12px;
    background: #0f9f6e;
  }

  .offer-summary small,
  .offer-summary strong {
    display: block;
  }

  .offer-summary small {
    color: #667085;
    font-size: 11px;
    font-weight: 700;
  }

  .offer-summary strong {
    margin-top: 2px;
    color: #173a2c;
    font-size: 15px;
    line-height: 1.35;
    overflow-wrap: anywhere;
  }

  .offer-badge.is-free,
  .offer-summary.is-free .offer-summary-label { background: #0f9f6e; }
  .offer-badge.is-credit,
  .offer-summary.is-credit .offer-summary-label { background: #2563eb; }
  .offer-badge.is-discount,
  .offer-summary.is-discount .offer-summary-label { background: #e9730c; }
  .offer-badge.is-trial,
  .offer-summary.is-trial .offer-summary-label { background: #0891b2; }
  .offer-badge.is-expired,
  .offer-summary.is-expired .offer-summary-label { background: #c43d3d; }
  .offer-badge.is-pending,
  .offer-summary.is-pending .offer-summary-label { background: #b77900; }
  .offer-badge.is-deal,
  .offer-summary.is-deal .offer-summary-label { background: #5147f5; }

  .offer-summary.is-credit { border-color: #cbdcff; background: #f2f7ff; }
  .offer-summary.is-credit strong { color: #173a73; }
  .offer-summary.is-discount { border-color: #ffd7ad; background: #fff8ef; }
  .offer-summary.is-discount strong { color: #71350d; }
  .offer-summary.is-trial { border-color: #b9e8ef; background: #f0fbfd; }
  .offer-summary.is-trial strong { color: #155260; }
  .offer-summary.is-expired { border-color: #f0caca; background: #fff5f5; }
  .offer-summary.is-expired strong { color: #7c2626; }
  .offer-summary.is-pending { border-color: #efdfb7; background: #fffaf0; }
  .offer-summary.is-pending strong { color: #6e4a00; }
  .offer-summary.is-deal { border-color: #d7d4ff; background: #f6f5ff; }
  .offer-summary.is-deal strong { color: #3730a3; }

  @media (max-width: 560px) {
    .offer-summary {
      grid-template-columns: 1fr;
      gap: 9px;
    }

    .offer-summary-label {
      width: fit-content;
      min-width: 0;
      min-height: 32px;
      padding: 0 12px;
    }
  }
</style>
