---
import type { Guide } from '../data/guides';
import { getGuideBrand, getGuidePresentationCategory } from '../data/guides';

interface Props {
  guide: Guide;
  initiallyHidden?: boolean;
  defaultOrder?: number;
}

const { guide, initiallyHidden = false, defaultOrder = 0 } = Astro.props;
const category = getGuidePresentationCategory(guide);

const contentPresentation = {
  '领取教程': { column: '主要权益', cta: '查看领取教程' },
  '状态核验': { column: '当前状态', cta: '查看状态与处理' },
  '方案对比': { column: '方案概览', cta: '查看怎么选' },
  '学校授权': { column: '授权内容', cta: '查看授权方式' },
  '风险说明': { column: '影响范围', cta: '查看风险说明' },
} as const;

const content = contentPresentation[guide.contentType as keyof typeof contentPresentation]
  ?? contentPresentation['领取教程'];

const presentationStatus = () => {
  if (guide.status === '已失效') return { label: '已结束', className: 'expired' };
  if (guide.status === '待验证') return { label: '待实测', className: 'pending' };
  if (category === '学校授权') return { label: '需学校授权', className: 'school' };
  if (category === '学生优惠') return { label: '需学生认证', className: 'student' };
  if (category === '限时活动') return { label: '限时活动', className: 'limited' };
  if (category === '地区限制') return { label: '部分地区可用', className: 'regional' };
  return { label: '可领取', className: 'available' };
};

const status = presentationStatus();
const brand = getGuideBrand(guide);
const benefits = [...new Set([
  ...(guide.benefits ?? []).map((item) => item.value),
  guide.dealPrice,
  guide.dealType,
].filter(Boolean))].slice(0, 3);

const verifiedText = guide.status === '待验证'
  ? `${guide.lastVerified} 页面核验 · 待实测`
  : `${guide.lastVerified} ${guide.verificationType}`;

const officialLabel = guide.status === '已失效'
  ? '官方状态'
  : guide.offerType === '学生优惠' || guide.offerType === '学校授权'
    ? '官方申请'
    : guide.offerKind === 'credit'
      ? '官方赠金'
      : '官方页面';
---

<article
  class:list={['topic-deal-row', `is-${status.className}`, `is-${guide.contentType}`, { 'is-initially-hidden': initiallyHidden }]}
  data-deal-card
  data-category={category}
  data-content-type={guide.contentType}
  data-title={guide.title}
  data-verified={guide.lastVerified}
  data-default-order={defaultOrder}
>
  <div class={`deal-brand-mark is-${brand.className}`} aria-hidden="true">{brand.label}</div>

  <div class="deal-summary">
    <div class="deal-title-line">
      <h3>{guide.title}</h3>
      <span class={`deal-status is-${status.className}`}>{status.label}</span>
    </div>
    <p>{guide.summary}</p>
    <div class="deal-meta" aria-label="优惠信息">
      <span><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="8" r="3"/><path d="M6 20c.5-4 2.5-6 6-6s5.5 2 6 6"/></svg>{guide.audience}</span>
      <span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3 20 6v6c0 5-3.4 8-8 9-4.6-1-8-4-8-9V6l8-3Z"/><path d="m8.5 12 2.2 2.2 4.8-5"/></svg>{guide.regionLabel ?? guide.region}</span>
      <span><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>{verifiedText}</span>
    </div>
  </div>

  <div class="deal-benefits">
    <span class="deal-column-label">{content.column}</span>
    <ul>
      {benefits.map((benefit) => <li><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m5 12 4 4L19 6"/></svg><span>{benefit}</span></li>)}
    </ul>
  </div>

  <div class="deal-actions">
    <a class="deal-primary-action" href={`/guides/${guide.slug}/`}>
      {content.cta}
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6"/></svg>
    </a>
    {guide.officialUrl ? (
      <a class="deal-secondary-action" href={guide.officialUrl} target="_blank" rel="noreferrer">
        {officialLabel}
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 5h5v5M13 11l6-6M19 13v6H5V5h6"/></svg>
      </a>
    ) : (
      <span class="deal-secondary-note">{guide.warning}</span>
    )}
  </div>
</article>
