---
import type { Guide } from '../data/guides';

interface Props {
  guide: Guide;
}

const { guide } = Astro.props;
---

<aside class="sidebar pro-sidebar" aria-label="优惠信息侧栏">
  <section class="sidebar-card deal-summary-card">
    <div class="sidebar-card-head">
      <span class="mini-label">领取判断</span>
      <h2>先看是否值得操作</h2>
    </div>

    <div class="deal-status-strip">
      <span class="badge success">{guide.status}</span>
      <strong>{guide.estimatedTime}</strong>
    </div>

    <div class="deal-box">
      <div class="deal-line"><span>优惠类型</span><strong>{guide.dealType}</strong></div>
      <div class="deal-line"><span>优惠价</span><strong>{guide.dealPrice}</strong></div>
      <div class="deal-line"><span>适用地区</span><strong>{guide.region}</strong></div>
      <div class="deal-line"><span>最后验证</span><strong>{guide.lastVerified}</strong></div>
    </div>

    <div class="coupon-box">
      <span>优惠码 / 口令</span>
      <code id="coupon-code">{guide.couponCode}</code>
      <button class="copy-btn" type="button" data-copy="#coupon-code">复制</button>
    </div>

    <a class="btn btn-primary" href="#steps">直接看领取步骤</a>
  </section>

  <section class="sidebar-card risk-card">
    <h3>本篇注意事项</h3>
    <p>{guide.warning}</p>
  </section>

  <section class="sidebar-card toc">
    <h3>阅读目录</h3>
    <a href="#overview">01 · 优惠概览</a>
    <a href="#prepare">02 · 领取前准备</a>
    <a href="#steps">03 · 详细操作步骤</a>
    <a href="#faq">04 · 常见失败原因</a>
    <a href="#article-body">05 · 补充说明</a>
  </section>
</aside>
