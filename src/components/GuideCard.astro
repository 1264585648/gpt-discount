---
import type { Guide } from '../data/guides';

interface Props {
  guide: Guide;
}

const { guide } = Astro.props;
---

<a
  class="guide-card pro-guide-card"
  href={`/guides/${guide.slug}/`}
  data-guide-card
  data-search-text={`${guide.title} ${guide.category} ${guide.summary} ${guide.audience} ${guide.dealType}`}
>
  <div class="card-top">
    <div class="badges">
      <span class="badge brand">{guide.category}</span>
      <span class="badge success">{guide.status}</span>
    </div>
    <span class="badge card-time">{guide.estimatedTime}</span>
  </div>

  <div class="guide-card-body">
    <h3>{guide.title}</h3>
    <p>{guide.summary}</p>
  </div>

  <div class="meta-row compact-meta-row" aria-label="教程关键信息">
    <div class="meta-item">
      <span>难度</span>
      <strong>{guide.difficulty}</strong>
    </div>
    <div class="meta-item">
      <span>对象</span>
      <strong>{guide.audience}</strong>
    </div>
    <div class="meta-item">
      <span>验证</span>
      <strong>{guide.lastVerified}</strong>
    </div>
  </div>

  <div class="card-footer">
    <span class="badge warning">含风险提醒</span>
    <span class="text-link">阅读全文 →</span>
  </div>
</a>
