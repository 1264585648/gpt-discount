---
import type { Guide } from '../data/guides';

interface Props {
  guide: Guide;
}

const { guide } = Astro.props;
---

<a
  class="guide-card"
  href={`/guides/${guide.slug}/`}
  data-guide-card
  data-search-text={`${guide.title} ${guide.category} ${guide.summary} ${guide.audience} ${guide.dealType}`}
>
  <div class="card-top">
    <div class="badges">
      <span class="badge brand">{guide.category}</span>
      <span class="badge success">{guide.status}</span>
    </div>
    <span class="badge">{guide.estimatedTime}</span>
  </div>

  <h3>{guide.title}</h3>
  <p>{guide.summary}</p>

  <div class="meta-row">
    <div class="meta-item">
      <span>难度</span>
      <strong>{guide.difficulty}</strong>
    </div>
    <div class="meta-item">
      <span>适合人群</span>
      <strong>{guide.audience}</strong>
    </div>
    <div class="meta-item">
      <span>最后验证</span>
      <strong>{guide.lastVerified}</strong>
    </div>
  </div>

  <div class="card-footer">
    <span class="badge warning">含注意事项</span>
    <span class="text-link">查看完整教程 →</span>
  </div>
</a>
