---
import type { Guide } from '../data/guides';
import { getGuideBrand } from '../data/guides';

interface Props {
  guide: Guide;
}

const { guide } = Astro.props;
const brand = getGuideBrand(guide);
const statusLabel = guide.status === '已失效'
  ? '已结束'
  : guide.status === '待验证'
    ? '待实测'
    : guide.contentType === '学校授权'
      ? '学校授权'
      : guide.contentType === '方案对比'
        ? '方案对比'
        : guide.status;
---

<a
  class={`home-guide-card is-${brand.className}`}
  href={`/guides/${guide.slug}/`}
  data-guide-card
  data-search-text={`${guide.title} ${guide.summary} ${guide.audience} ${guide.category} ${guide.dealPrice}`}
>
  <span class={`home-guide-brand is-${brand.className}`} aria-hidden="true">{brand.label}</span>
  <span class="home-guide-copy">
    <span class="home-guide-meta"><em>{statusLabel}</em><small>{guide.contentType}</small></span>
    <strong>{guide.title}</strong>
    <span>{guide.dealPrice}</span>
  </span>
  <span class="home-guide-side">
    <small>{guide.lastVerified} 核验</small>
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6"/></svg>
  </span>
</a>

<style>
  .home-guide-card {
    min-width: 0;
    min-height: 100px;
    display: grid !important;
    grid-template-columns: 42px minmax(0, 1fr) auto;
    align-items: center;
    gap: 13px;
    padding: 14px 16px !important;
    border: 1px solid #e5e9f0 !important;
    border-radius: 13px !important;
    background: #fff !important;
    transition: border-color .18s ease, box-shadow .18s ease, transform .18s ease;
  }

  .home-guide-card:hover {
    border-color: #cfd5e2 !important;
    box-shadow: 0 10px 24px rgba(15, 23, 42, .06);
    transform: translateY(-1px);
  }

  .home-guide-brand {
    width: 42px;
    height: 42px;
    display: grid;
    place-items: center;
    color: #fff;
    border-radius: 12px;
    background: #4f46e5;
    font-size: 11px;
    font-weight: 850;
  }

  .home-guide-brand.is-github { background: #111; }
  .home-guide-brand.is-jetbrains { background: linear-gradient(135deg, #ff3d00, #ec008c 50%, #6d28d9); }
  .home-guide-brand.is-notion { background: #111; }
  .home-guide-brand.is-google { background: #4285f4; }
  .home-guide-brand.is-microsoft { background: #2563eb; }
  .home-guide-brand.is-adobe { background: #e11d48; }
  .home-guide-brand.is-figma { background: #111827; }
  .home-guide-brand.is-canva { background: #0ea5a8; }
  .home-guide-brand.is-cloudflare { background: #f97316; }

  .home-guide-copy,
  .home-guide-copy strong,
  .home-guide-copy > span,
  .home-guide-side small { display: block; min-width: 0; }

  .home-guide-meta {
    display: flex !important;
    align-items: center;
    gap: 7px;
    margin-bottom: 5px;
  }

  .home-guide-meta em {
    padding: 2px 6px;
    color: #4338ca;
    font-size: 9px;
    font-style: normal;
    font-weight: 750;
    border-radius: 999px;
    background: #eef2ff;
  }

  .home-guide-meta small {
    color: #8a92a3;
    font-size: 9px;
  }

  .home-guide-copy strong {
    overflow: hidden;
    color: #182033;
    font-size: 14px;
    line-height: 1.35;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .home-guide-copy > span:last-child {
    margin-top: 5px;
    overflow: hidden;
    color: #697184;
    font-size: 11px;
    line-height: 1.4;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .home-guide-side {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #8a92a3;
  }

  .home-guide-side small { font-size: 9px; white-space: nowrap; }
  .home-guide-side svg { width: 18px; height: 18px; fill: none; stroke: currentColor; stroke-width: 1.8; }

  @media (max-width: 620px) {
    .home-guide-card { grid-template-columns: 38px minmax(0, 1fr) 18px; padding: 13px !important; }
    .home-guide-brand { width: 38px; height: 38px; border-radius: 10px; }
    .home-guide-side small { display: none; }
    .home-guide-copy strong { white-space: normal; }
  }
</style>
